<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PathFinder</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    html,body{width:100%;height:100%}
    body{font-family:sans-serif;background:#09090f;color:#e8e6f0;min-height:100vh;display:flex;align-items:center;justify-content:center}
    .bg{position:fixed;inset:0;background:radial-gradient(ellipse 60% 50% at 20% 50%,rgba(108,99,255,.18),transparent 70%);z-index:0;pointer-events:none}
    .wrap{position:relative;z-index:1;text-align:center;padding:2rem}
    h1{font-size:3rem;font-weight:700;margin-bottom:1rem;color:#fff}
    h1 span{background:linear-gradient(135deg,#9D6BFF,#6C63FF);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    p{font-size:17px;color:rgba(232,230,240,.55);max-width:500px;margin:0 auto 2.5rem;line-height:1.7}
    .btns{display:flex;gap:1.2rem;justify-content:center;flex-wrap:wrap}
    .btn{display:flex;flex-direction:column;align-items:center;gap:.4rem;padding:1.5rem 2.5rem;border-radius:18px;text-decoration:none;font-weight:600;font-size:1rem;transition:transform .2s;min-width:190px}
    .btn-client{background:linear-gradient(135deg,#6C63FF,#9D6BFF);color:#fff}
    .btn-client:hover{transform:translateY(-4px)}
    .btn-admin{background:rgba(255,255,255,.04);border:.5px solid rgba(255,255,255,.1);color:#e8e6f0}
    .btn-admin:hover{transform:translateY(-4px)}
    .sub{font-size:.78rem;opacity:.55;margin-top:.2rem}
  </style>
</head>
<body>
  <div class="bg"></div>
  <div class="wrap">
    <h1>Bienvenue sur<br><span>PathFinder</span></h1>
    <p>Accedez a votre espace selon votre profil.</p>
    <div class="btns">
      <a href="{{ path('offre_list') }}" class="btn btn-client">
        <span style="font-size:2rem">&#128188;</span>
        Espace Candidat
        <span class="sub">Offres &amp; Candidatures</span>
      </a>
      <a href="{{ path('offre_index') }}" class="btn btn-admin">
        <span style="font-size:2rem">&#9881;</span>
        Espace Admin RH
        <span class="sub">Tableau de bord</span>
      </a>
    </div>
  </div>
</body>
</html>
