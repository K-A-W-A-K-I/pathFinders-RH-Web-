<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Admin — PathFinder{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('css/app.css') }}?v={{ 'now'|date('U') }}">
    <link rel="stylesheet" href="{{ asset('css/admin.css') }}?v={{ 'now'|date('U') }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
    /* Dashboard compat styles */
    :root{--bg:#f4f5fb;--primary:#6c63ff;--primary-light:#ede9ff;--white:#ffffff;--text-dark:#1a1d2e;--text-mid:#4b5563;--text-light:#9ca3af;--border:#e5e7ef;--radius:14px;--shadow:0 2px 16px rgba(108,99,255,0.07)}
    .topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:32px}
    .page-title{display:flex;align-items:center;gap:12px}
    .page-title h1{font-family:'Sora',sans-serif;font-size:22px;font-weight:700;color:var(--text-dark);letter-spacing:-.01em}
    .btn-primary{background:var(--primary);color:#fff;border:none;padding:11px 22px;border-radius:12px;font-size:14px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;transition:background .18s,transform .12s,box-shadow .18s;box-shadow:0 4px 14px rgba(108,99,255,.28);text-decoration:none;display:inline-block}
    .btn-primary:hover{background:#5a52e0;transform:translateY(-1px);color:#fff}
    .btn-secondary{background:var(--white);border:1.5px solid var(--border);color:var(--text-mid);padding:7px 14px;border-radius:8px;font-size:13px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;text-decoration:none;display:inline-block;transition:border-color .15s,color .15s}
    .btn-secondary:hover{border-color:var(--primary);color:var(--primary)}
    .table-section{background:var(--white);border-radius:var(--radius);box-shadow:var(--shadow);border:1px solid var(--border);padding:24px 28px;animation:fadeUp .5s ease .1s both;margin-bottom:24px}
    .table-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:22px;flex-wrap:wrap;gap:12px}
    .table-title{display:flex;align-items:center;gap:10px}
    .table-title h2{font-family:'Sora',sans-serif;font-size:16px;font-weight:700}
    .count-badge{background:var(--primary-light);color:var(--primary);font-size:12px;font-weight:600;padding:3px 10px;border-radius:20px}
    .table-actions{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
    .search-input{border:1.5px solid var(--border);border-radius:9px;padding:7px 14px;font-size:13px;font-family:'DM Sans',sans-serif;color:var(--text-dark);outline:none;width:180px;transition:border-color .15s;background:#fafbff}
    .search-input:focus{border-color:var(--primary)}
    .pf-select{border:1.5px solid var(--border);border-radius:9px;padding:7px 14px;font-size:13px;font-family:'DM Sans',sans-serif;color:var(--text-dark);outline:none;background:#fafbff;cursor:pointer}
    .action-btns{display:flex;align-items:center;gap:6px;justify-content:flex-end}
    .btn-action{height:30px;padding:0 10px;border-radius:8px;border:1.5px solid var(--border);background:var(--white);color:var(--text-light);display:inline-flex;align-items:center;gap:5px;cursor:pointer;font-size:12px;font-weight:500;font-family:'DM Sans',sans-serif;transition:border-color .15s,color .15s,background .15s;text-decoration:none;white-space:nowrap}
    .btn-action:hover{border-color:var(--primary);color:var(--primary);background:var(--primary-light)}
    .btn-action.danger:hover{border-color:#ef4444;color:#ef4444;background:#fef2f2}
    .btn-action.success{border-color:#22c55e;color:#22c55e}
    .btn-action.success:hover{background:#f0fdf4}
    .tag{display:inline-block;padding:4px 11px;border-radius:20px;font-size:12px;font-weight:500}
    .tag-green{background:#dcfce7;color:#16a34a}
    .tag-red{background:#fee2e2;color:#dc2626}
    .tag-blue{background:#eff6ff;color:#3b82f6}
    .tag-purple{background:var(--primary-light);color:var(--primary)}
    .form-section{background:var(--white);border-radius:var(--radius);box-shadow:var(--shadow);border:1px solid var(--border);padding:32px;max-width:700px;animation:fadeUp .5s ease both}
    .form-group{margin-bottom:1.2rem}
    .form-group label{display:block;font-size:13px;font-weight:600;color:var(--text-mid);margin-bottom:.4rem}
    .form-group input,.form-group textarea,.form-group select{width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:9px;font-size:14px;font-family:'DM Sans',sans-serif;color:var(--text-dark);outline:none;transition:border-color .15s;background:#fafbff}
    .form-group input:focus,.form-group textarea:focus,.form-group select:focus{border-color:var(--primary)}
    .form-hint{font-size:11.5px;color:var(--text-light);margin-top:.3rem}
    .form-errors{color:#dc2626;font-size:12px;margin-top:.3rem;display:flex;align-items:center;gap:4px}
    .flash{padding:.75rem 1.25rem;margin:.5rem 0 1rem;border-radius:8px;font-size:14px;display:flex;align-items:center;gap:.5rem}
    .flash-success{background:#dcfce7;border:1px solid #86efac;color:#15803d}
    .flash-error{background:#fee2e2;border:1px solid #fca5a5;color:#dc2626}
    .flash-warning{background:#fef9c3;border:1px solid #fde047;color:#b45309}
    @keyframes fadeUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body class="admin-body">

<div class="admin-layout">

    <!-- ── Sidebar ── -->
    <aside class="admin-sidebar">
        <div class="sidebar-logo">
            <img src="{{ asset('logowhite.png') }}" alt="PathFinder" class="sidebar-logo-img">
            <span class="sidebar-logo-text">PATHFINDER</span>
        </div>

        <nav class="sidebar-nav">
            <div class="sidebar-section-label">GESTION</div>
            <a href="{{ path('user_index') }}"
               class="sidebar-link {{ app.request.attributes.get('_route') starts with 'user_' ? 'active' : '' }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                Gestion des Utilisateurs
            </a>
            <a href="{{ path('offre_index') }}"
               class="sidebar-link {{ app.request.attributes.get('_route') in ['offre_index','offre_new','offre_show','offre_edit','question_new','question_edit'] ? 'active' : '' }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                Gestion des Offres
            </a>
            <a href="{{ path('admin_candidatures') }}"
               class="sidebar-link {{ app.request.attributes.get('_route') == 'admin_candidatures' ? 'active' : '' }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                Candidatures
            </a>
            <a href="{{ path('entretien_admin') }}"
               class="sidebar-link {{ app.request.attributes.get('_route') == 'entretien_admin' ? 'active' : '' }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                Entretiens
            </a>
            <a href="{{ path('evenement_index') }}"
               class="sidebar-link {{ app.request.attributes.get('_route') starts with 'evenement_' ? 'active' : '' }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                Événements
            </a>
            <a href="{{ path('dashboard_home') }}"
               class="sidebar-link {{ app.request.attributes.get('_route') == 'dashboard_home' or app.request.attributes.get('_route') starts with 'dashboard_formation' or app.request.attributes.get('_route') starts with 'dashboard_categorie' or app.request.attributes.get('_route') starts with 'dashboard_contenu' ? 'active' : '' }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                Formations
            </a>
            <a href="{{ path('fiche_index') }}"
               class="sidebar-link {{ app.request.attributes.get('_route') starts with 'fiche_' ? 'active' : '' }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                Fiches de Paie
            </a>
            <a href="{{ path('prime_index') }}"
               class="sidebar-link {{ app.request.attributes.get('_route') starts with 'prime_' ? 'active' : '' }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
                Primes
            </a>
            <a href="{{ path('admin_reclamation_index') }}"
               class="sidebar-link {{ app.request.attributes.get('_route') starts with 'admin_reclamation_' ? 'active' : '' }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                Réclamations
            </a>

        </nav>

        <div class="sidebar-footer">
            {% if app.user %}
                <div class="sidebar-user">
                    <div class="sidebar-avatar">{{ app.user.fullName|slice(0,2)|upper }}</div>
                    <span class="sidebar-username">{{ app.user.fullName }}</span>
                </div>
            {% endif %}
            <a href="{{ path('auth_logout') }}" class="sidebar-logout">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                Déconnexion
            </a>
        </div>
    </aside>

    <!-- ── Main ── -->
    <main class="admin-main">
        <div class="admin-topbar">
            <div class="admin-topbar-left">
                <div class="admin-page-icon">{% block page_icon %}📄{% endblock %}</div>
                <h1 class="admin-page-title">{% block page_title %}{% endblock %}</h1>
            </div>
            <div class="admin-topbar-right">
                {% block topbar_actions %}{% endblock %}
            </div>
        </div>

        <div class="admin-content">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="pf-alert pf-alert-{{ type }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </div>
    </main>
</div>

{% block javascripts %}{% endblock %}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
const saved = localStorage.getItem('pf-theme') || 'dark';
document.documentElement.setAttribute('data-theme', saved);
</script>
</body>
</html>
