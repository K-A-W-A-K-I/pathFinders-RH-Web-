{% extends 'admin_base.html.twig' %}
{% block title %}Gestion des Offres{% endblock %}
{% block page_icon %}📋{% endblock %}
{% block page_title %}Gestion des Offres{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('offre_new') }}" class="btn btn-primary">＋ Nouvelle Offre</a>
{% endblock %}

{% block body %}

{# ── Quick action cards ── #}
<div class="admin-quick-cards">
    <div class="quick-card">
        <div class="quick-card-icon" style="background:rgba(108,99,255,0.12)">📁</div>
        <div class="quick-card-body">
            <div class="quick-card-title">Consulter Candidatures</div>
            <div class="quick-card-sub">Voir et gérer toutes les candidatures reçues par offre</div>
        </div>
        <a href="{{ path('admin_candidatures') }}" class="quick-card-btn">Voir →</a>
        <span class="quick-card-badge">{{ offres|length }} offres</span>
    </div>
    <div class="quick-card">
        <div class="quick-card-icon" style="background:rgba(245,158,11,0.12)">❓</div>
        <div class="quick-card-body">
            <div class="quick-card-title">Gestion des Questions</div>
            <div style="display:flex;gap:12px;margin-top:6px;flex-wrap:wrap">
                <span style="font-size:12px;color:#6b6b8a">📝 <strong style="color:#1a1730">{{ totalQuestions }}</strong> questions</span>
                <span style="font-size:12px;color:#6b6b8a">📋 <strong style="color:#1a1730">{{ offres|length }}</strong> offres</span>
                {% if offresWithoutQuestions > 0 %}
                    <span style="font-size:12px;color:#d97706;font-weight:600">⚠️ {{ offresWithoutQuestions }} sans questions</span>
                {% else %}
                    <span style="font-size:12px;color:#16a34a;font-weight:600">✅ Toutes couvertes</span>
                {% endif %}
            </div>
            {% if offresWithoutQuestions > 0 %}
            <button onclick="bulkGenerate()" id="bulk-btn"
                    style="margin-top:10px;display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:8px;font-size:12.5px;font-weight:600;background:linear-gradient(135deg,#6C63FF,#9D6BFF);color:#fff;border:none;cursor:pointer;width:100%">
                🤖 Générer pour les {{ offresWithoutQuestions }} offre(s) sans questions
            </button>
            <div id="bulk-status" style="font-size:12px;margin-top:6px;color:#6C63FF;display:none"></div>
            {% endif %}
        </div>
        <span class="quick-card-badge quick-card-badge-amber">Tests actifs</span>
    </div>
    <div class="quick-card quick-card-featured">
        <div class="quick-card-icon" style="background:rgba(239,68,68,0.12)">🤖</div>
        <div class="quick-card-body">
            <div class="quick-card-title" style="color:#f97316">Analyser CV par IA</div>
            {% if totalCv == 0 %}
                <div class="quick-card-sub">Aucune candidature avec CV pour le moment.</div>
            {% elseif analysedCv == totalCv %}
                <div class="quick-card-sub" style="color:#16a34a;font-weight:600">✅ Tous les CVs analysés ({{ totalCv }})</div>
            {% else %}
                <div class="quick-card-sub">{{ analysedCv }}/{{ totalCv }} CVs analysés</div>
                <div style="margin-top:8px;height:6px;background:#f0f0f8;border-radius:4px;overflow:hidden">
                    <div style="height:6px;border-radius:4px;background:linear-gradient(90deg,#f97316,#fb923c);width:{{ totalCv > 0 ? ((analysedCv / totalCv) * 100)|round : 0 }}%;transition:width .4s"></div>
                </div>
            {% endif %}
        </div>
        {% if totalCv == 0 %}
            <span class="quick-card-btn quick-card-btn-orange" style="opacity:.5;cursor:default">Aucun CV</span>
        {% elseif analysedCv == totalCv %}
            <a href="{{ path('admin_candidatures') }}" class="quick-card-btn" style="background:rgba(22,163,74,.1);color:#16a34a;border:1px solid rgba(22,163,74,.3)">Voir résultats →</a>
        {% else %}
            <a href="{{ path('admin_candidatures') }}" class="quick-card-btn quick-card-btn-orange">Continuer →</a>
        {% endif %}
        <span class="quick-card-badge quick-card-badge-orange">IA OpenRouter</span>
    </div>
</div>

{# ── Offres table ── #}
<div class="admin-table-section">
    <div class="admin-table-header">
        <div class="admin-table-title">
            Liste des Offres
            <span class="admin-count-badge">{{ offres|length }} offres</span>
        </div>
        <div class="admin-table-actions">
            <button class="admin-tool-btn">⊙ Filtrer</button>
            <input type="text" placeholder="Rechercher..." class="admin-search-input" id="offreSearch">
        </div>
    </div>

    {% if offres is empty %}
        <div class="empty-state">
            <div class="empty-icon">📄</div>
            <p class="empty-title">Aucune offre créée</p>
            <a href="{{ path('offre_new') }}" class="btn btn-primary">＋ Créer une offre</a>
        </div>
    {% else %}
    <table class="admin-table" id="offreTable">
        <thead>
            <tr>
                <th>TITRE</th>
                <th>DOMAINE</th>
                <th>CONTRAT</th>
                <th>SALAIRE</th>
                <th>SCORE MIN.</th>
                <th>DURÉE TEST</th>
                <th>STATUT</th>
                <th>ACTIONS</th>
            </tr>
        </thead>
        <tbody>
        {% for offre in offres %}
        <tr>
            <td class="admin-table-name">{{ offre.titre }}</td>
            <td><span class="admin-badge admin-badge-blue">{{ offre.domaine }}</span></td>
            <td><span class="admin-badge admin-badge-green">{{ offre.typeContrat }}</span></td>
            <td class="admin-table-muted">{{ offre.salaireMin }} – {{ offre.salaireMax }} DT</td>
            <td>
                <div class="admin-score-bar">
                    <div class="admin-score-fill" style="width:{{ offre.scoreMinimum }}%"></div>
                </div>
                {{ offre.scoreMinimum }}%
            </td>
            <td class="admin-table-muted">{{ offre.dureeTestMinutes }} min</td>
            <td>
                <span class="admin-status-dot {{ offre.statut == 'active' ? 'dot-active' : 'dot-inactive' }}">
                    ● {{ offre.statut }}
                </span>
            </td>
            <td>
                <div class="admin-row-actions">
                    <a href="{{ path('offre_show', {id: offre.id}) }}" class="admin-action-btn" title="Voir">—</a>
                    <form method="post" action="{{ path('offre_delete', {id: offre.id}) }}" onsubmit="return confirm('Supprimer ?')" style="display:inline">
                        <button type="submit" class="admin-action-btn admin-action-delete" title="Supprimer">🗑</button>
                    </form>
                </div>
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>

<script>
document.getElementById('offreSearch')?.addEventListener('input', function() {
    const q = this.value.toLowerCase();
    document.querySelectorAll('#offreTable tbody tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
});

function bulkGenerate() {
    const btn    = document.getElementById('bulk-btn');
    const status = document.getElementById('bulk-status');
    btn.disabled = true;
    btn.textContent = '⏳ Génération en cours...';
    status.style.display = 'block';
    status.textContent = 'Appel à l\'IA pour chaque offre, veuillez patienter...';

    fetch('/admin/offres/bulk-generate-questions', { method: 'POST' })
    .then(r => r.json())
    .then(data => {
        if (data.success) {
            if (data.count === 0) {
                status.textContent = '✅ Toutes les offres ont déjà des questions.';
            } else {
                status.textContent = `✅ ${data.questions} questions générées pour ${data.count} offre(s) !`;
                if (data.errors && data.errors.length > 0) {
                    status.textContent += ` (${data.errors.length} erreur(s))`;
                }
                btn.style.display = 'none';
                setTimeout(() => location.reload(), 2000);
            }
        } else {
            status.style.color = '#f87171';
            status.textContent = '❌ Erreur : ' + (data.error ?? 'inconnue');
            btn.disabled = false;
            btn.textContent = '🤖 Réessayer';
        }
    })
    .catch(() => {
        status.style.color = '#f87171';
        status.textContent = '❌ Erreur réseau';
        btn.disabled = false;
    });
}
</script>
{% endblock %}
