{% extends 'admin_base.html.twig' %}
{% block title %}{{ offre.titre }}{% endblock %}
{% block page_icon %}📋{% endblock %}
{% block page_title %}{{ offre.titre }}{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('offre_edit', {id: offre.id}) }}" class="btn btn-edit" style="display:inline-flex;align-items:center;gap:6px;padding:9px 18px;border-radius:10px;font-weight:600;text-decoration:none;background:rgba(108,99,255,.1);color:#6C63FF;border:1px solid rgba(108,99,255,.3)">✏️ Modifier</a>
    <form method="post" action="{{ path('offre_delete', {id: offre.id}) }}" onsubmit="return confirm('Supprimer cette offre ?')" style="display:inline">
        <button type="submit" class="btn btn-danger" style="display:inline-flex;align-items:center;gap:6px;padding:9px 18px;border-radius:10px;font-weight:600;background:#ef4444;color:#fff;border:none;cursor:pointer">🗑 Supprimer</button>
    </form>
    <a href="{{ path('offre_index') }}" class="btn btn-secondary" style="display:inline-flex;align-items:center;gap:6px;padding:9px 18px;border-radius:10px;font-weight:600;text-decoration:none;background:var(--white);color:var(--text-light);border:1px solid var(--border)">← Retour</a>
{% endblock %}

{% block body %}

<div class="tabs" id="tabs">
    <button class="tab-btn tab-active" onclick="showTab('infos', this)">ℹ️ Informations</button>
    <button class="tab-btn" onclick="showTab('candidatures', this)">👥 Candidatures ({{ candidatures|length }})</button>
    <button class="tab-btn" onclick="showTab('questions', this)" id="questions">❓ Questions ({{ questions|length }})</button>
    <button class="tab-btn" onclick="showTab('entretiens', this)">📅 Entretiens ({{ entretiens|length }})</button>
</div>

{# ── Informations ── #}
<div id="tab-infos" class="tab-content">
    <div class="info-grid">
        <div class="info-item"><span class="info-label">Salaire</span><span>{{ offre.salaireMin }} – {{ offre.salaireMax }} DT</span></div>
        <div class="info-item"><span class="info-label">Contrat</span><span>{{ offre.typeContrat }}</span></div>
        <div class="info-item"><span class="info-label">Score minimum</span><span>{{ offre.scoreMinimum }}%</span></div>
        <div class="info-item"><span class="info-label">Durée du test</span><span>{{ offre.dureeTestMinutes }} min</span></div>
        <div class="info-item info-full"><span class="info-label">Description</span><p>{{ offre.description }}</p></div>
    </div>
</div>

{# ── Candidatures ── #}
<div id="tab-candidatures" class="tab-content" style="display:none">
    {% if candidatures is empty %}
        <p class="empty-sub">Aucune candidature pour cette offre.</p>
    {% else %}

    {# Toolbar #}
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;flex-wrap:wrap">
        <span style="font-size:13px;color:var(--text-light)">{{ candidatures|length }} candidat(s)</span>
        <div style="margin-left:auto;display:flex;gap:8px;align-items:center">
            <button onclick="openChartModal()" class="btn" style="background:linear-gradient(135deg,#6C63FF,#9D6BFF);color:#fff;border:none;font-weight:600">
                📊 Visualiser
            </button>
        </div>
    </div>

    {# Ranking table #}
    <table class="data-table" id="ranking-table">
        <thead>
            <tr>
                <th>Rang</th>
                <th>Candidat</th>
                <th>Score Quiz <small style="font-weight:400;color:#9999b8">(20%)</small></th>
                <th>Score CV IA <small style="font-weight:400;color:#9999b8">(80%)</small></th>
                <th>Score Final</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for i, c in candidatures %}
        {% set final = finalScores[c.id] %}
        <tr data-name="{{ c.candidat.fullName }}" data-quiz="{{ c.score }}" data-cv="{{ c.cvScoreIa ?? '' }}" data-final="{{ final }}">
            <td style="font-size:18px;text-align:center">
                {{ i == 0 ? '🥇' : (i == 1 ? '🥈' : (i == 2 ? '🥉' : '#' ~ (i+1))) }}
            </td>
            <td style="font-weight:600">{{ c.candidat.fullName }}</td>
            <td><strong>{{ c.score }}%</strong></td>
            <td id="cv-score-{{ c.id }}">
                {% if c.cvScoreIa is not null %}
                    <span style="color:#6C63FF;font-weight:600">{{ c.cvScoreIa }}%</span>
                    {% if c.candidat.cvScoreDetails %}
                        <span title="{{ c.candidat.cvScoreDetails }}" style="cursor:help;color:#9999b8;font-size:11px"> ℹ️</span>
                    {% endif %}
                {% else %}
                    <button class="btn btn-sm" style="background:rgba(108,99,255,.1);color:#6C63FF;border:1px solid rgba(108,99,255,.3);font-size:11px"
                            onclick="analyseCv({{ c.id }}, this)">🤖 Analyser CV</button>
                {% endif %}
            </td>
            <td>
                <div style="display:flex;align-items:center;gap:8px">
                    <div style="flex:1;height:8px;background:#f0f0f8;border-radius:4px;min-width:60px">
                        <div style="height:8px;border-radius:4px;background:{{ final >= 70 ? '#4ade80' : (final >= 40 ? '#facc15' : '#f87171') }};width:{{ final }}%"></div>
                    </div>
                    <strong style="color:{{ final >= 70 ? '#16a34a' : (final >= 40 ? '#ca8a04' : '#dc2626') }}">{{ final }}%</strong>
                </div>
            </td>
            <td><span class="badge {{ c.statutClass }}">{{ c.statutLabel }}</span></td>
            <td>
                <div class="admin-row-actions">
                    <form method="post" action="{{ path('candidature_statut', {id: c.id, statut: 1}) }}" style="display:inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('statut' ~ c.id) }}">
                        <button class="btn btn-sm btn-success" {{ c.statutAdmin == 1 ? 'disabled' : '' }} title="Accepter">✅</button>
                    </form>
                    <form method="post" action="{{ path('candidature_statut', {id: c.id, statut: -1}) }}" style="display:inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('statut' ~ c.id) }}">
                        <button class="btn btn-sm btn-danger" {{ c.statutAdmin == -1 ? 'disabled' : '' }} title="Refuser">❌</button>
                    </form>
                    {% if not c.candidat.isBlacklisted %}
                    <button type="button"
                            class="btn btn-sm"
                            style="background:rgba(239,68,68,.1);color:#dc2626;border:1px solid rgba(239,68,68,.3)"
                            title="Refuser & Blacklister"
                            onclick="openBlacklistModal({{ c.id }}, '{{ c.candidat.fullName|e('js') }}')">
                        🚫
                    </button>
                    {% else %}
                    <span title="Blacklisté : {{ c.candidat.blacklistNote }}" style="font-size:13px;cursor:help">🚫✓</span>
                    {% endif %}
                </div>
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>

{# ── Blacklist Modal ── #}
<div id="blacklist-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9999;align-items:center;justify-content:center">
    <div style="background:#fff;border-radius:16px;padding:28px;max-width:460px;width:95%;position:relative">
        <button onclick="closeBlacklistModal()" style="position:absolute;top:14px;right:16px;background:none;border:none;font-size:20px;cursor:pointer;color:#666">✕</button>
        <h3 style="margin:0 0 6px;font-size:16px;font-weight:700;color:#dc2626">🚫 Refuser & Blacklister</h3>
        <p id="blacklist-candidat-name" style="margin:0 0 18px;font-size:13px;color:#666"></p>
        <form id="blacklist-form" method="post">
            <input type="hidden" name="_token" id="blacklist-token">
            <label style="font-size:13px;font-weight:600;color:#374151;display:block;margin-bottom:6px">Note (raison du blacklist)</label>
            <textarea name="blacklist_note" id="blacklist-note" rows="3"
                      placeholder="Ex: Faux diplômes, No-show entretien..."
                      style="width:100%;padding:10px 12px;border:1px solid #e5e7eb;border-radius:8px;font-size:13px;resize:vertical;box-sizing:border-box"></textarea>
            <div style="display:flex;gap:10px;margin-top:16px;justify-content:flex-end">
                <button type="button" onclick="closeBlacklistModal()"
                        style="padding:9px 18px;border-radius:8px;border:1px solid #e5e7eb;background:#fff;font-weight:600;cursor:pointer;font-size:13px">
                    Annuler
                </button>
                <button type="submit"
                        style="padding:9px 18px;border-radius:8px;border:none;background:#dc2626;color:#fff;font-weight:600;cursor:pointer;font-size:13px">
                    🚫 Confirmer le blacklist
                </button>
            </div>
        </form>
    </div>
</div>

{# ── Chart Modal ── #}
<div id="chart-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);backdrop-filter:blur(4px);z-index:9999;align-items:center;justify-content:center">
    <div style="background:var(--bg-card);border:1px solid var(--border-card);border-radius:20px;padding:28px;max-width:820px;width:95%;max-height:90vh;overflow-y:auto;position:relative;box-shadow:var(--shadow-lg)">
        <button onclick="closeChartModal()" style="position:absolute;top:14px;right:16px;background:rgba(255,255,255,.08);border:1px solid var(--border-card);border-radius:8px;width:32px;height:32px;font-size:16px;cursor:pointer;color:var(--text-muted);display:flex;align-items:center;justify-content:center;line-height:1">✕</button>
        <h3 style="margin:0 0 4px;font-family:'Sora',sans-serif;font-size:16px;font-weight:700;color:var(--text-heading)">📊 {{ offre.titre }}</h3>
        <p style="font-size:13px;color:var(--text-muted);margin-bottom:20px">Visualisation des scores candidats</p>

        {# Chart type tabs #}
        <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:20px">
            <button class="chart-tab-btn chart-tab-active" onclick="switchChart('bar', this)">📊 Barres</button>
            <button class="chart-tab-btn" onclick="switchChart('horizontalBar', this)">📊 Horizontal</button>
            <button class="chart-tab-btn" onclick="switchChart('line', this)">📈 Ligne</button>
            <button class="chart-tab-btn" onclick="switchChart('radar', this)">🕸️ Radar</button>
            <button class="chart-tab-btn" onclick="switchChart('doughnut', this)">🍩 Donut</button>
            <button class="chart-tab-btn" onclick="switchChart('pie', this)">🥧 Camembert</button>
        </div>

        <div style="position:relative;height:380px">
            <canvas id="candidatChart"></canvas>
        </div>

        <div style="margin-top:16px;display:flex;justify-content:flex-end;gap:8px">
            <button onclick="downloadChart()" class="btn btn-secondary" style="font-size:13px">⬇️ Télécharger PNG</button>
            <button onclick="closeChartModal()" class="btn btn-secondary" style="font-size:13px">Fermer</button>
        </div>
    </div>
</div>

{# ── Questions ── #}
<div id="tab-questions" class="tab-content" style="display:none">
    <div class="section-actions" style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
        <a href="{{ path('question_new', {id: offre.id}) }}" class="btn btn-primary">＋ Ajouter une question</a>
        <button type="button" class="btn" style="background:linear-gradient(135deg,#6C63FF,#9D6BFF);color:#fff;border:none"
                onclick="generateQuestions({{ offre.id }})">
            🤖 Générer avec IA
        </button>
        <select id="ia-count" style="padding:8px 12px;border-radius:8px;border:1px solid var(--border);font-size:13px">
            <option value="3">3 questions</option>
            <option value="5" selected>5 questions</option>
            <option value="8">8 questions</option>
            <option value="10">10 questions</option>
        </select>
        <span id="ia-status" style="font-size:13px;color:#6C63FF"></span>
    </div>
    {% if questions is empty %}
        <p class="empty-sub">Aucune question pour cette offre.</p>
    {% else %}
    {% for q in questions %}
    <div class="question-item">
        <div class="question-item-header">
            <span class="question-text-preview">{{ q.question }}</span>
            <span class="badge badge-points">{{ q.points }} pt(s)</span>
        </div>
        <div class="choices-preview">
            {% for idx, choice in q.choices %}
                <span class="choice-preview {{ idx == q.bonneReponse ? 'choice-correct' : '' }}">{{ choice }}</span>
            {% endfor %}
        </div>
        <div class="question-item-actions">
            <a href="{{ path('question_edit', {id: q.id}) }}" class="btn btn-sm btn-edit">✏️</a>
            <form method="post" action="{{ path('question_delete', {id: q.id}) }}" onsubmit="return confirm('Supprimer ?')" style="display:inline">
                <button class="btn btn-sm btn-danger">🗑</button>
            </form>
        </div>
    </div>
    {% endfor %}
    {% endif %}
</div>

{# ── Entretiens ── #}
<div id="tab-entretiens" class="tab-content" style="display:none">
    {% if entretiens is empty %}
        <p class="empty-sub">Aucun entretien pour cette offre.</p>
    {% else %}
    <table class="data-table">
        <thead><tr><th>Candidat</th><th>Date</th><th>Statut</th><th>Notes</th></tr></thead>
        <tbody>
        {% for e in entretiens %}
        <tr>
            <td>{{ e.candidat.fullName }}</td>
            <td>{{ e.dateEntretien|date('d/m/Y H:i') }}</td>
            <td><span class="badge {{ e.statutClass }}">{{ e.statutLabel }}</span></td>
            <td>{{ e.notes ?? '—' }}</td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
function showTab(name, btn) {
    document.querySelectorAll('.tab-content').forEach(t => t.style.display = 'none');
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('tab-active'));
    document.getElementById('tab-' + name).style.display = '';
    btn.classList.add('tab-active');
}
if (location.hash === '#questions') showTab('questions', document.querySelector('[onclick*="questions"]'));

// ── Chart ──────────────────────────────────────────────────────────────
let chartInstance = null;
let currentChartType = 'bar';

// Detect dark mode from html attribute
function isDark() {
    return document.documentElement.getAttribute('data-theme') !== 'light';
}

function getChartColors() {
    return isDark() ? {
        grid:    'rgba(255,255,255,0.06)',
        tick:    'rgba(232,230,240,0.45)',
        legend:  'rgba(232,230,240,0.7)',
        tooltip: { bg: '#1a1838', border: 'rgba(108,99,255,.4)', title: '#e8e6f0', body: 'rgba(232,230,240,.75)' },
    } : {
        grid:    'rgba(0,0,0,0.06)',
        tick:    '#6b7280',
        legend:  '#374151',
        tooltip: { bg: '#ffffff', border: 'rgba(108,99,255,.25)', title: '#1a1d2e', body: '#4b5563' },
    };
}

function getChartData() {
    const rows = document.querySelectorAll('#ranking-table tbody tr');
    const labels = [], quizData = [], cvData = [], finalData = [];
    rows.forEach(row => {
        labels.push(row.dataset.name);
        quizData.push(parseInt(row.dataset.quiz) || 0);
        cvData.push(row.dataset.cv !== '' ? parseInt(row.dataset.cv) : 0);
        finalData.push(parseInt(row.dataset.final) || 0);
    });
    return { labels, quizData, cvData, finalData };
}

function buildChartConfig(type) {
    const { labels, quizData, cvData, finalData } = getChartData();
    const c = getChartColors();
    const isRound = type === 'doughnut' || type === 'pie';
    const isRadar = type === 'radar';
    const isHBar  = type === 'horizontalBar';
    const realType = isHBar ? 'bar' : type;

    const palette = ['#6C63FF','#9D6BFF','#4ade80','#facc15','#f87171','#60a5fa','#fb923c','#a78bfa','#34d399','#f472b6'];

    const baseDataset = {
        borderWidth: 2,
        borderRadius: isRound || isRadar ? 0 : 8,
        pointRadius: 5,
        pointHoverRadius: 7,
        tension: 0.4,
    };

    let datasets;
    if (isRound) {
        datasets = [{
            ...baseDataset,
            label: 'Score Final',
            data: finalData,
            backgroundColor: palette.slice(0, labels.length).map(c => c + 'cc'),
            borderColor: palette.slice(0, labels.length),
            hoverOffset: 10,
        }];
    } else if (isRadar) {
        datasets = [
            { ...baseDataset, label: 'Score CV IA', data: cvData, borderColor: '#6C63FF', backgroundColor: 'rgba(108,99,255,.15)', pointBackgroundColor: '#6C63FF', fill: true },
            { ...baseDataset, label: 'Score Quiz',  data: quizData, borderColor: '#4ade80', backgroundColor: 'rgba(74,222,128,.12)', pointBackgroundColor: '#4ade80', fill: true },
            { ...baseDataset, label: 'Score Final', data: finalData, borderColor: '#9D6BFF', backgroundColor: 'rgba(157,107,255,.1)', pointBackgroundColor: '#9D6BFF', fill: true },
        ];
    } else {
        datasets = [
            { ...baseDataset, label: 'Score Final', data: finalData, backgroundColor: 'rgba(108,99,255,.75)', borderColor: '#6C63FF', hoverBackgroundColor: '#6C63FF' },
            { ...baseDataset, label: 'Score CV IA', data: cvData,    backgroundColor: 'rgba(157,107,255,.55)', borderColor: '#9D6BFF', hoverBackgroundColor: '#9D6BFF' },
            { ...baseDataset, label: 'Score Quiz',  data: quizData,  backgroundColor: 'rgba(74,222,128,.55)',  borderColor: '#4ade80', hoverBackgroundColor: '#4ade80' },
        ];
    }

    const scaleDefaults = {
        grid: { color: c.grid },
        ticks: { color: c.tick, font: { family: "'DM Sans', sans-serif", size: 12 } },
    };

    return {
        type: realType,
        data: { labels, datasets },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            animation: { duration: 500, easing: 'easeOutQuart' },
            indexAxis: isHBar ? 'y' : 'x',
            plugins: {
                legend: {
                    position: isRound ? 'bottom' : 'top',
                    labels: {
                        color: c.legend,
                        font: { family: "'DM Sans', sans-serif", size: 12 },
                        padding: 16,
                        usePointStyle: true,
                        pointStyleWidth: 10,
                    },
                },
                tooltip: {
                    backgroundColor: c.tooltip.bg,
                    borderColor: c.tooltip.border,
                    borderWidth: 1,
                    titleColor: c.tooltip.title,
                    bodyColor: c.tooltip.body,
                    padding: 12,
                    cornerRadius: 10,
                    titleFont: { family: "'Sora', sans-serif", size: 13, weight: '700' },
                    bodyFont: { family: "'DM Sans', sans-serif", size: 12 },
                    callbacks: {
                        label: ctx => ` ${ctx.dataset.label}: ${ctx.parsed.y ?? ctx.parsed.r ?? ctx.parsed}%`
                    }
                },
            },
            scales: isRound ? {} : isRadar ? {
                r: {
                    beginAtZero: true, max: 100,
                    grid: { color: c.grid },
                    ticks: { color: c.tick, backdropColor: 'transparent', stepSize: 20 },
                    pointLabels: { color: c.legend, font: { family: "'DM Sans', sans-serif", size: 11 } },
                }
            } : {
                x: { ...scaleDefaults, ...(isHBar ? { max: 100 } : {}) },
                y: { ...scaleDefaults, ...(isHBar ? {} : { beginAtZero: true, max: 100, ticks: { ...scaleDefaults.ticks, callback: v => v + '%' } }) },
            },
        },
    };
}

function renderChart(type) {
    const ctx = document.getElementById('candidatChart').getContext('2d');
    if (chartInstance) { chartInstance.destroy(); chartInstance = null; }
    chartInstance = new Chart(ctx, buildChartConfig(type));
}

function switchChart(type, btn) {
    currentChartType = type;
    document.querySelectorAll('.chart-tab-btn').forEach(b => b.classList.remove('chart-tab-active'));
    btn.classList.add('chart-tab-active');
    renderChart(type);
}

function openChartModal() {
    document.getElementById('chart-modal').style.display = 'flex';
    setTimeout(() => renderChart(currentChartType), 50);
}
function closeChartModal() {
    document.getElementById('chart-modal').style.display = 'none';
}
document.getElementById('chart-modal').addEventListener('click', function(e) {
    if (e.target === this) closeChartModal();
});

function downloadChart() {
    const canvas = document.getElementById('candidatChart');
    const link = document.createElement('a');
    link.download = 'candidats-{{ offre.titre|replace({' ': '-'})|lower }}.png';
    link.href = canvas.toDataURL('image/png');
    link.click();
}

// ── AI: Generate questions ─────────────────────────────────────────────
function generateQuestions(offreId) {
    const count  = document.getElementById('ia-count').value;
    const status = document.getElementById('ia-status');
    status.textContent = '⏳ Génération en cours...';

    fetch(`/admin/offres/${offreId}/generate-questions`, {
        method: 'POST',
        headers: {'Content-Type': 'application/x-www-form-urlencoded'},
        body: `count=${count}`,
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) {
            status.textContent = `✅ ${data.count} questions générées !`;
            setTimeout(() => location.reload(), 1200);
        } else {
            status.textContent = '❌ Erreur : ' + data.error;
        }
    })
    .catch(() => { status.textContent = '❌ Erreur réseau'; });
}

// ── Blacklist Modal ────────────────────────────────────────────────────
const blacklistUrls = {
    {% for c in candidatures %}
    {{ c.id }}: "{{ path('candidature_blacklist', {id: c.id}) }}",
    {% endfor %}
};
const blacklistTokens = {
    {% for c in candidatures %}
    {{ c.id }}: "{{ csrf_token('blacklist' ~ c.id) }}",
    {% endfor %}
};

function openBlacklistModal(candidatureId, candidatName) {
    document.getElementById('blacklist-candidat-name').textContent = 'Candidat : ' + candidatName;
    document.getElementById('blacklist-form').action = blacklistUrls[candidatureId];
    document.getElementById('blacklist-token').value = blacklistTokens[candidatureId];
    document.getElementById('blacklist-note').value = '';
    document.getElementById('blacklist-modal').style.display = 'flex';
}
function closeBlacklistModal() {
    document.getElementById('blacklist-modal').style.display = 'none';
}
document.getElementById('blacklist-modal').addEventListener('click', function(e) {
    if (e.target === this) closeBlacklistModal();
});

// ── AI: Analyse CV ─────────────────────────────────────────────────────
function analyseCv(candidatureId, btn) {
    btn.textContent = '⏳...';
    btn.disabled = true;

    fetch(`/admin/offres/candidature/${candidatureId}/analyse-cv`, { method: 'POST' })
    .then(r => r.json())
    .then(data => {
        const cell = document.getElementById('cv-score-' + candidatureId);
        if (data.success) {
            cell.innerHTML = `<span style="color:#6C63FF;font-weight:600">${data.score}%</span>`
                + (data.details ? ` <span title="${data.details.replace(/"/g,"'")}" style="cursor:help;color:#9999b8;font-size:11px">ℹ️</span>` : '');
            const row = cell.closest('tr');
            if (row) {
                row.dataset.cv = data.score;
                const quiz = parseInt(row.dataset.quiz) || 0;
                const newFinal = Math.round(data.score * 0.8 + quiz * 0.2);
                row.dataset.final = newFinal;
                const finalCell = row.cells[4];
                if (finalCell) {
                    const color = newFinal >= 70 ? '#16a34a' : (newFinal >= 40 ? '#ca8a04' : '#dc2626');
                    const bg    = newFinal >= 70 ? '#4ade80' : (newFinal >= 40 ? '#facc15' : '#f87171');
                    finalCell.innerHTML = `<div style="display:flex;align-items:center;gap:8px"><div style="flex:1;height:8px;background:#f0f0f8;border-radius:4px;min-width:60px"><div style="height:8px;border-radius:4px;background:${bg};width:${newFinal}%"></div></div><strong style="color:${color}">${newFinal}%</strong></div>`;
                }
            }
        } else {
            cell.innerHTML = `<span style="color:#f87171;font-size:11px">${data.error}</span>`;
        }
    })
    .catch(() => {
        document.getElementById('cv-score-' + candidatureId).innerHTML = '<span style="color:#f87171;font-size:11px">Erreur réseau</span>';
    });
}
</script>

<style>
.chart-tab-btn{padding:7px 14px;border-radius:8px;border:1px solid var(--border-card);background:var(--bg-th);color:var(--text-muted);font-size:12.5px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .15s}
.chart-tab-btn:hover{border-color:rgba(108,99,255,.4);color:var(--accent)}
.chart-tab-active{background:rgba(108,99,255,.15);border-color:rgba(108,99,255,.5);color:var(--accent);font-weight:600}
</style>
{% endblock %}
