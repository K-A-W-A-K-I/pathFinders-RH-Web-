{% extends 'admin_base.html.twig' %}
{% block title %}{{ offre.titre }}{% endblock %}
{% block page_icon %}📋{% endblock %}
{% block page_title %}{{ offre.titre }}{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('offre_edit', {id: offre.id}) }}" class="btn btn-edit" style="display:inline-flex;align-items:center;gap:6px;padding:9px 18px;border-radius:10px;font-weight:600;text-decoration:none;background:rgba(108,99,255,.1);color:#6C63FF;border:1px solid rgba(108,99,255,.3)">✏️ Modifier</a>
    <form method="post" action="{{ path('offre_delete', {id: offre.id}) }}" onsubmit="return confirm('Supprimer cette offre ?')" style="display:inline">
        <button type="submit" class="btn btn-danger" style="display:inline-flex;align-items:center;gap:6px;padding:9px 18px;border-radius:10px;font-weight:600;background:#ef4444;color:#fff;border:none;cursor:pointer">🗑 Supprimer</button>
    </form>
    <a href="{{ path('offre_index') }}" class="btn btn-secondary" style="display:inline-flex;align-items:center;gap:6px;padding:9px 18px;border-radius:10px;font-weight:600;text-decoration:none;background:var(--white);color:var(--text-light);border:1px solid var(--border)">← Retour</a>
{% endblock %}

{% block body %}

<div class="tabs" id="tabs">
    <button class="tab-btn tab-active" onclick="showTab('infos', this)">ℹ️ Informations</button>
    <button class="tab-btn" onclick="showTab('candidatures', this)">👥 Candidatures ({{ candidatures|length }})</button>
    <button class="tab-btn" onclick="showTab('questions', this)" id="questions">❓ Questions ({{ questions|length }})</button>
    <button class="tab-btn" onclick="showTab('entretiens', this)">📅 Entretiens ({{ entretiens|length }})</button>
</div>

{# ── Informations ── #}
<div id="tab-infos" class="tab-content">
    <div class="info-grid">
        <div class="info-item"><span class="info-label">Salaire</span><span>{{ offre.salaireMin }} – {{ offre.salaireMax }} DT</span></div>
        <div class="info-item"><span class="info-label">Contrat</span><span>{{ offre.typeContrat }}</span></div>
        <div class="info-item"><span class="info-label">Score minimum</span><span>{{ offre.scoreMinimum }}%</span></div>
        <div class="info-item"><span class="info-label">Durée du test</span><span>{{ offre.dureeTestMinutes }} min</span></div>
        <div class="info-item info-full"><span class="info-label">Description</span><p>{{ offre.description }}</p></div>
    </div>
</div>

{# ── Candidatures ── #}
<div id="tab-candidatures" class="tab-content" style="display:none">
    {% if candidatures is empty %}
        <p class="empty-sub">Aucune candidature pour cette offre.</p>
    {% else %}

    {# Toolbar #}
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;flex-wrap:wrap">
        <span style="font-size:13px;color:var(--text-light)">{{ candidatures|length }} candidat(s)</span>
        <div style="margin-left:auto;display:flex;gap:8px;align-items:center">
            <select id="chart-type" style="padding:8px 12px;border-radius:8px;border:1px solid var(--border);font-size:13px;background:var(--white)">
                <option value="bar">📊 Barres</option>
                <option value="horizontalBar">📊 Barres horizontales</option>
                <option value="doughnut">🍩 Donut</option>
                <option value="pie">🥧 Camembert</option>
                <option value="radar">🕸️ Radar</option>
                <option value="line">📈 Ligne</option>
            </select>
            <button onclick="openChartModal()" class="btn" style="background:linear-gradient(135deg,#6C63FF,#9D6BFF);color:#fff;border:none;font-weight:600">
                📊 Générer graphique
            </button>
        </div>
    </div>

    {# Ranking table #}
    <table class="data-table" id="ranking-table">
        <thead>
            <tr>
                <th>Rang</th>
                <th>Candidat</th>
                <th>Score Quiz <small style="font-weight:400;color:#9999b8">(20%)</small></th>
                <th>Score CV IA <small style="font-weight:400;color:#9999b8">(80%)</small></th>
                <th>Score Final</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for i, c in candidatures %}
        {% set final = finalScores[c.id] %}
        <tr data-name="{{ c.candidat.fullName }}" data-quiz="{{ c.score }}" data-cv="{{ c.cvScoreIa ?? '' }}" data-final="{{ final }}">
            <td style="font-size:18px;text-align:center">
                {{ i == 0 ? '🥇' : (i == 1 ? '🥈' : (i == 2 ? '🥉' : '#' ~ (i+1))) }}
            </td>
            <td style="font-weight:600">{{ c.candidat.fullName }}</td>
            <td><strong>{{ c.score }}%</strong></td>
            <td id="cv-score-{{ c.id }}">
                {% if c.cvScoreIa is not null %}
                    <span style="color:#6C63FF;font-weight:600">{{ c.cvScoreIa }}%</span>
                    {% if c.candidat.cvScoreDetails %}
                        <span title="{{ c.candidat.cvScoreDetails }}" style="cursor:help;color:#9999b8;font-size:11px"> ℹ️</span>
                    {% endif %}
                {% else %}
                    <button class="btn btn-sm" style="background:rgba(108,99,255,.1);color:#6C63FF;border:1px solid rgba(108,99,255,.3);font-size:11px"
                            onclick="analyseCv({{ c.id }}, this)">🤖 Analyser CV</button>
                {% endif %}
            </td>
            <td>
                <div style="display:flex;align-items:center;gap:8px">
                    <div style="flex:1;height:8px;background:#f0f0f8;border-radius:4px;min-width:60px">
                        <div style="height:8px;border-radius:4px;background:{{ final >= 70 ? '#4ade80' : (final >= 40 ? '#facc15' : '#f87171') }};width:{{ final }}%"></div>
                    </div>
                    <strong style="color:{{ final >= 70 ? '#16a34a' : (final >= 40 ? '#ca8a04' : '#dc2626') }}">{{ final }}%</strong>
                </div>
            </td>
            <td><span class="badge {{ c.statutClass }}">{{ c.statutLabel }}</span></td>
            <td>
                <div class="admin-row-actions">
                    <form method="post" action="{{ path('candidature_statut', {id: c.id, statut: 1}) }}" style="display:inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('statut' ~ c.id) }}">
                        <button class="btn btn-sm btn-success" {{ c.statutAdmin == 1 ? 'disabled' : '' }} title="Accepter">✅</button>
                    </form>
                    <form method="post" action="{{ path('candidature_statut', {id: c.id, statut: -1}) }}" style="display:inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('statut' ~ c.id) }}">
                        <button class="btn btn-sm btn-danger" {{ c.statutAdmin == -1 ? 'disabled' : '' }} title="Refuser">❌</button>
                    </form>
                </div>
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>

{# ── Chart Modal ── #}
<div id="chart-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9999;align-items:center;justify-content:center">
    <div style="background:#fff;border-radius:16px;padding:28px;max-width:780px;width:95%;max-height:90vh;overflow-y:auto;position:relative">
        <button onclick="closeChartModal()" style="position:absolute;top:14px;right:16px;background:none;border:none;font-size:20px;cursor:pointer;color:#666">✕</button>
        <h3 style="margin:0 0 20px;font-size:16px;font-weight:700;color:#1a1730">📊 Graphique des candidats — {{ offre.titre }}</h3>
        <div id="chart-container" style="text-align:center">
            <p style="color:#9999b8">Génération en cours...</p>
        </div>
        <div style="margin-top:16px;text-align:center">
            <a id="chart-download" href="#" download="chart.png" style="display:none" class="btn btn-secondary">⬇️ Télécharger</a>
        </div>
    </div>
</div>

{# ── Questions ── #}
<div id="tab-questions" class="tab-content" style="display:none">
    <div class="section-actions" style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
        <a href="{{ path('question_new', {id: offre.id}) }}" class="btn btn-primary">＋ Ajouter une question</a>
        <button type="button" class="btn" style="background:linear-gradient(135deg,#6C63FF,#9D6BFF);color:#fff;border:none"
                onclick="generateQuestions({{ offre.id }})">
            🤖 Générer avec IA
        </button>
        <select id="ia-count" style="padding:8px 12px;border-radius:8px;border:1px solid var(--border);font-size:13px">
            <option value="3">3 questions</option>
            <option value="5" selected>5 questions</option>
            <option value="8">8 questions</option>
            <option value="10">10 questions</option>
        </select>
        <span id="ia-status" style="font-size:13px;color:#6C63FF"></span>
    </div>
    {% if questions is empty %}
        <p class="empty-sub">Aucune question pour cette offre.</p>
    {% else %}
    {% for q in questions %}
    <div class="question-item">
        <div class="question-item-header">
            <span class="question-text-preview">{{ q.question }}</span>
            <span class="badge badge-points">{{ q.points }} pt(s)</span>
        </div>
        <div class="choices-preview">
            {% for idx, choice in q.choices %}
                <span class="choice-preview {{ idx == q.bonneReponse ? 'choice-correct' : '' }}">{{ choice }}</span>
            {% endfor %}
        </div>
        <div class="question-item-actions">
            <a href="{{ path('question_edit', {id: q.id}) }}" class="btn btn-sm btn-edit">✏️</a>
            <form method="post" action="{{ path('question_delete', {id: q.id}) }}" onsubmit="return confirm('Supprimer ?')" style="display:inline">
                <button class="btn btn-sm btn-danger">🗑</button>
            </form>
        </div>
    </div>
    {% endfor %}
    {% endif %}
</div>

{# ── Entretiens ── #}
<div id="tab-entretiens" class="tab-content" style="display:none">
    {% if entretiens is empty %}
        <p class="empty-sub">Aucun entretien pour cette offre.</p>
    {% else %}
    <table class="data-table">
        <thead><tr><th>Candidat</th><th>Date</th><th>Statut</th><th>Notes</th></tr></thead>
        <tbody>
        {% for e in entretiens %}
        <tr>
            <td>{{ e.candidat.fullName }}</td>
            <td>{{ e.dateEntretien|date('d/m/Y H:i') }}</td>
            <td><span class="badge {{ e.statutClass }}">{{ e.statutLabel }}</span></td>
            <td>{{ e.notes ?? '—' }}</td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>

<script>
function showTab(name, btn) {
    document.querySelectorAll('.tab-content').forEach(t => t.style.display = 'none');
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('tab-active'));
    document.getElementById('tab-' + name).style.display = '';
    btn.classList.add('tab-active');
}
if (location.hash === '#questions') showTab('questions', document.querySelector('[onclick*="questions"]'));

// ── Chart Modal ────────────────────────────────────────────────────────
function openChartModal() {
    const modal = document.getElementById('chart-modal');
    modal.style.display = 'flex';
    generateChart();
}
function closeChartModal() {
    document.getElementById('chart-modal').style.display = 'none';
}
document.getElementById('chart-modal').addEventListener('click', function(e) {
    if (e.target === this) closeChartModal();
});

function generateChart() {
    const type = document.getElementById('chart-type').value;
    const rows = document.querySelectorAll('#ranking-table tbody tr');

    const labels = [], quizData = [], cvData = [];
    rows.forEach(row => {
        labels.push(row.dataset.name);
        quizData.push(parseInt(row.dataset.quiz) || 0);
        cvData.push(row.dataset.cv !== '' ? parseInt(row.dataset.cv) : 0);
    });

    let config;
    const isRound = type === 'doughnut' || type === 'pie';

    if (isRound) {
        // For doughnut/pie: show CV IA scores (or quiz if no CV)
        config = {
            type: type,
            data: {
                labels: labels,
                datasets: [{
                    label: 'Score CV IA',
                    data: cvData,
                    backgroundColor: ['#6C63FF','#9D6BFF','#4ade80','#facc15','#f87171','#60a5fa','#fb923c','#a78bfa'],
                }]
            },
            options: { plugins: { legend: { position: 'bottom' } } }
        };
    } else if (type === 'radar') {
        config = {
            type: 'radar',
            data: {
                labels: labels,
                datasets: [
                    { label: 'Score CV IA', data: cvData, borderColor: '#6C63FF', backgroundColor: 'rgba(108,99,255,.15)', pointBackgroundColor: '#6C63FF' },
                    { label: 'Score Quiz', data: quizData, borderColor: '#4ade80', backgroundColor: 'rgba(74,222,128,.1)', pointBackgroundColor: '#4ade80' },
                ]
            },
            options: { scales: { r: { beginAtZero: true, max: 100 } } }
        };
    } else {
        const chartType = type === 'horizontalBar' ? 'bar' : type;
        config = {
            type: chartType,
            data: {
                labels: labels,
                datasets: [
                    { label: 'Score Quiz', data: quizData, backgroundColor: 'rgba(74,222,128,.7)', borderColor: '#4ade80', borderWidth: 2, borderRadius: 6 },
                    { label: 'Score CV IA', data: cvData, backgroundColor: 'rgba(108,99,255,.7)', borderColor: '#6C63FF', borderWidth: 2, borderRadius: 6 },
                ]
            },
            options: {
                indexAxis: type === 'horizontalBar' ? 'y' : 'x',
                scales: { y: { beginAtZero: true, max: 100 } },
                plugins: { legend: { position: 'bottom' } }
            }
        };
    }

    const url = 'https://quickchart.io/chart?w=700&h=400&c=' + encodeURIComponent(JSON.stringify(config));
    const container = document.getElementById('chart-container');
    container.innerHTML = '<img src="' + url + '" style="max-width:100%;border-radius:10px" onload="this.style.opacity=1" onerror="this.parentElement.innerHTML=\'<p style=color:#f87171>Erreur de génération du graphique</p>\'">';

    const dl = document.getElementById('chart-download');
    dl.href = url;
    dl.style.display = 'inline-block';
}

// Re-generate when chart type changes (if modal open)
document.getElementById('chart-type').addEventListener('change', function() {
    if (document.getElementById('chart-modal').style.display === 'flex') generateChart();
});

// ── AI: Generate questions ─────────────────────────────────────────────
function generateQuestions(offreId) {
    const count  = document.getElementById('ia-count').value;
    const status = document.getElementById('ia-status');
    status.textContent = '⏳ Génération en cours...';

    fetch(`/admin/offres/${offreId}/generate-questions`, {
        method: 'POST',
        headers: {'Content-Type': 'application/x-www-form-urlencoded'},
        body: `count=${count}`,
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) {
            status.textContent = `✅ ${data.count} questions générées !`;
            setTimeout(() => location.reload(), 1200);
        } else {
            status.textContent = '❌ Erreur : ' + data.error;
        }
    })
    .catch(() => { status.textContent = '❌ Erreur réseau'; });
}

// ── AI: Analyse CV ─────────────────────────────────────────────────────
function analyseCv(candidatureId, btn) {
    btn.textContent = '⏳...';
    btn.disabled = true;

    fetch(`/admin/offres/candidature/${candidatureId}/analyse-cv`, { method: 'POST' })
    .then(r => r.json())
    .then(data => {
        const cell = document.getElementById('cv-score-' + candidatureId);
        if (data.success) {
            cell.innerHTML = `<span style="color:#6C63FF;font-weight:600">${data.score}%</span>`
                + (data.details ? ` <span title="${data.details.replace(/"/g,"'")}" style="cursor:help;color:#9999b8;font-size:11px">ℹ️</span>` : '');
            // Update data-cv on the row for chart
            const row = cell.closest('tr');
            if (row) {
                row.dataset.cv = data.score;
                const quiz = parseInt(row.dataset.quiz) || 0;
                const newFinal = Math.round(data.score * 0.8 + quiz * 0.2);
                row.dataset.final = newFinal;
                // Update final score cell (5th td)
                const finalCell = row.cells[4];
                if (finalCell) {
                    const color = newFinal >= 70 ? '#16a34a' : (newFinal >= 40 ? '#ca8a04' : '#dc2626');
                    const bg    = newFinal >= 70 ? '#4ade80' : (newFinal >= 40 ? '#facc15' : '#f87171');
                    finalCell.innerHTML = `<div style="display:flex;align-items:center;gap:8px"><div style="flex:1;height:8px;background:#f0f0f8;border-radius:4px;min-width:60px"><div style="height:8px;border-radius:4px;background:${bg};width:${newFinal}%"></div></div><strong style="color:${color}">${newFinal}%</strong></div>`;
                }
            }
        } else {
            cell.innerHTML = `<span style="color:#f87171;font-size:11px">${data.error}</span>`;
        }
    })
    .catch(() => {
        document.getElementById('cv-score-' + candidatureId).innerHTML = '<span style="color:#f87171;font-size:11px">Erreur réseau</span>';
    });
}
</script>
{% endblock %}
