<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Entretien déjà complété</title>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ asset('css/app.css') }}?v={{ 'now'|date('U') }}">
</head>
<body class="pf-body">
<div class="pf-bg">
  <div class="pf-bg-grid"></div>
  <div class="pf-bg-glow pf-bg-glow-1"></div>
  <div class="pf-bg-glow pf-bg-glow-2"></div>
</div>
<nav class="pf-nav">
  <div class="pf-logo">
    <img src="{{ asset('logowhite.png') }}" alt="PathFinder" style="height:32px;">
    <span class="pf-logo-text">PATHFINDER</span>
  </div>
</nav>
<div class="auth-wrapper">
  <div class="auth-card" style="text-align:center">
    <div style="font-size:52px;margin-bottom:16px">✅</div>
    <h1 class="auth-title">Entretien complété</h1>
    <p class="auth-subtitle" style="margin-bottom:20px">Vous avez déjà passé l'entretien IA pour le poste <strong style="color:var(--accent)">{{ entretien.offre.titre }}</strong>.</p>
    {% if entretien.interviewScore is not null %}
    <div style="background:linear-gradient(135deg,rgba(108,99,255,.12),rgba(157,107,255,.08));border:1px solid rgba(108,99,255,.25);border-radius:14px;padding:20px;margin:0 0 16px">
      <div style="font-size:12px;color:var(--accent-text);margin-bottom:6px;font-weight:600;text-transform:uppercase;letter-spacing:.06em">Votre score</div>
      <div style="font-family:'Sora',sans-serif;font-size:42px;font-weight:800;color:var(--accent);line-height:1">{{ entretien.interviewScore }}<span style="font-size:18px;color:var(--text-muted)">/100</span></div>
    </div>
    {% endif %}
    <p style="font-size:13px;color:var(--text-muted)">Vos résultats ont été transmis à l'équipe RH.<br>Vous serez contacté prochainement.</p>
  </div>
</div>
</body>
</html>
