{% extends 'base.html.twig' %}
{% block title %}Inscription{% endblock %}

{% block body %}
<div class="auth-wrapper">
    <div class="auth-card auth-card-wide">

        <div class="auth-header">
            <div class="auth-logo">PF</div>
            <h1 class="auth-title">Créer un compte</h1>
            <p class="auth-subtitle">Rejoignez Pathfinders et trouvez votre prochain emploi</p>
        </div>

        {{ form_start(form, {attr: {class: 'auth-form'}}) }}

            {% if not form.vars.valid and form.vars.submitted %}
            <div class="alert alert-error">
                ⚠️ Veuillez corriger les erreurs ci-dessous.
            </div>
            {% endif %}

            <div class="form-grid-2">
                <div class="form-group">
                    {{ form_label(form.nom) }}
                    {{ form_widget(form.nom, {attr: {class: form.nom.vars.errors|length > 0 ? 'input-error' : ''}}) }}
                    {{ form_errors(form.nom) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.prenom) }}
                    {{ form_widget(form.prenom, {attr: {class: form.prenom.vars.errors|length > 0 ? 'input-error' : ''}}) }}
                    {{ form_errors(form.prenom) }}
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.email) }}
                {{ form_widget(form.email, {attr: {class: form.email.vars.errors|length > 0 ? 'input-error' : ''}}) }}
                {{ form_errors(form.email) }}
            </div>

            <div class="form-grid-2">
                <div class="form-group">
                    {{ form_label(form.plainPassword.first) }}
                    {{ form_widget(form.plainPassword.first, {attr: {class: form.plainPassword.vars.errors|length > 0 ? 'input-error' : ''}}) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.plainPassword.second) }}
                    {{ form_widget(form.plainPassword.second, {attr: {class: form.plainPassword.vars.errors|length > 0 ? 'input-error' : ''}}) }}
                </div>
            </div>
            {{ form_errors(form.plainPassword) }}

            <button type="submit" class="btn btn-auth-signup">
                ✅ Créer mon compte
            </button>

        {{ form_end(form) }}

        <div class="auth-footer">
            Déjà un compte ?
            <a href="{{ path('auth_login') }}">Se connecter</a>
        </div>

    </div>
</div>
{% endblock %}
