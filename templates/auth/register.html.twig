<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Inscription — PathFinder</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;font-family:'DM Sans',sans-serif}
body{
  min-height:100vh;
  background:#09090f;
  display:flex;align-items:center;justify-content:center;
  padding:40px 16px;
  position:relative;
}
.bg-glow{position:fixed;border-radius:50%;filter:blur(100px);pointer-events:none;z-index:0}
.bg-glow-1{width:600px;height:600px;background:radial-gradient(circle,rgba(108,99,255,.18),transparent 70%);top:-150px;left:-150px}
.bg-glow-2{width:400px;height:400px;background:radial-gradient(circle,rgba(157,107,255,.12),transparent 70%);bottom:-100px;right:-100px}
.bg-grid{position:fixed;inset:0;background-image:linear-gradient(rgba(255,255,255,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.025) 1px,transparent 1px);background-size:48px 48px;z-index:0;pointer-events:none}

.auth-card{
  position:relative;z-index:1;
  width:100%;max-width:480px;
  background:rgba(255,255,255,.04);
  border:.5px solid rgba(255,255,255,.1);
  border-radius:24px;
  padding:44px 40px;
  backdrop-filter:blur(20px);
  box-shadow:0 32px 80px rgba(0,0,0,.4);
  animation:slideUp .4s cubic-bezier(.22,.68,0,1.2) both;
}
@keyframes slideUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}

.auth-logo{
  width:56px;height:56px;border-radius:16px;
  background:linear-gradient(135deg,#6C63FF,#9D6BFF);
  display:flex;align-items:center;justify-content:center;
  font-family:'Sora',sans-serif;font-weight:700;font-size:18px;color:#fff;
  margin:0 auto 24px;
  box-shadow:0 8px 24px rgba(108,99,255,.4);
}
.auth-title{font-family:'Sora',sans-serif;font-size:24px;font-weight:700;color:#fff;text-align:center;margin-bottom:6px}
.auth-sub{font-size:14px;color:rgba(232,230,240,.5);text-align:center;margin-bottom:32px}

.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.form-group{margin-bottom:14px}
label{display:block;font-size:12px;font-weight:600;color:rgba(232,230,240,.6);letter-spacing:.04em;text-transform:uppercase;margin-bottom:6px}
input{
  width:100%;padding:12px 16px;
  background:rgba(255,255,255,.06);
  border:.5px solid rgba(255,255,255,.12);
  border-radius:12px;
  color:#e8e6f0;font-size:14px;font-family:'DM Sans',sans-serif;
  outline:none;transition:border-color .2s,background .2s;
}
input::placeholder{color:rgba(232,230,240,.3)}
input:focus{border-color:rgba(108,99,255,.6);background:rgba(108,99,255,.08)}
input.is-invalid{border-color:rgba(226,75,74,.6)}
.field-error{color:#f87171;font-size:12px;margin-top:4px}

.btn-auth{
  width:100%;padding:13px;margin-top:8px;
  background:linear-gradient(135deg,#6C63FF,#9D6BFF);
  border:none;border-radius:12px;
  color:#fff;font-size:15px;font-weight:600;font-family:'DM Sans',sans-serif;
  cursor:pointer;transition:opacity .2s,transform .15s;
  box-shadow:0 6px 20px rgba(108,99,255,.4);
}
.btn-auth:hover{opacity:.9;transform:translateY(-1px)}

.auth-footer{text-align:center;margin-top:24px;font-size:13.5px;color:rgba(232,230,240,.45)}
.auth-footer a{color:#9D6BFF;text-decoration:none;font-weight:500}
.auth-footer a:hover{text-decoration:underline}

.back-home{position:fixed;top:24px;left:28px;z-index:10;display:flex;align-items:center;gap:8px;text-decoration:none;color:rgba(232,230,240,.5);font-size:13px;transition:color .2s}
.back-home:hover{color:#e8e6f0}
.back-home img{height:28px}
</style>
</head>
<body>
<div class="bg-glow bg-glow-1"></div>
<div class="bg-glow bg-glow-2"></div>
<div class="bg-grid"></div>

<a href="{{ path('offre_list') }}" class="back-home">
  <img src="{{ asset('logowhite.png') }}" alt="PathFinder">
  PathFinder
</a>

<div class="auth-card">
  <div class="auth-logo">PF</div>
  <h1 class="auth-title">Créer un compte</h1>
  <p class="auth-sub">Rejoignez PathFinder et trouvez votre prochain emploi</p>

  {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

  <div class="form-row">
    <div class="form-group">
      <label>Nom *</label>
      {{ form_widget(form.nom, {attr: {placeholder: 'Votre nom', class: form.nom.vars.errors|length ? 'is-invalid' : ''}}) }}
      {% for e in form.nom.vars.errors %}<div class="field-error">{{ e.message }}</div>{% endfor %}
    </div>
    <div class="form-group">
      <label>Prénom *</label>
      {{ form_widget(form.prenom, {attr: {placeholder: 'Votre prénom', class: form.prenom.vars.errors|length ? 'is-invalid' : ''}}) }}
      {% for e in form.prenom.vars.errors %}<div class="field-error">{{ e.message }}</div>{% endfor %}
    </div>
  </div>

  <div class="form-group">
    <label>Adresse email *</label>
    {{ form_widget(form.email, {attr: {placeholder: 'exemple@email.com', class: form.email.vars.errors|length ? 'is-invalid' : ''}}) }}
    {% for e in form.email.vars.errors %}<div class="field-error">{{ e.message }}</div>{% endfor %}
  </div>

  <div class="form-row">
    <div class="form-group">
      <label>Mot de passe *</label>
      {{ form_widget(form.plainPassword.first, {attr: {placeholder: 'Min. 6 caractères', class: form.plainPassword.vars.errors|length ? 'is-invalid' : ''}}) }}
    </div>
    <div class="form-group">
      <label>Confirmer *</label>
      {{ form_widget(form.plainPassword.second, {attr: {placeholder: 'Répétez', class: form.plainPassword.vars.errors|length ? 'is-invalid' : ''}}) }}
    </div>
  </div>
  {% for e in form.plainPassword.vars.errors %}<div class="field-error" style="margin-top:-8px;margin-bottom:10px">{{ e.message }}</div>{% endfor %}

  <button type="submit" class="btn-auth">✨ Créer mon compte</button>

  {{ form_end(form) }}

  <div class="auth-footer">
    Déjà un compte ? <a href="{{ path('auth_login') }}">Se connecter</a>
  </div>
</div>
</body>
</html>
