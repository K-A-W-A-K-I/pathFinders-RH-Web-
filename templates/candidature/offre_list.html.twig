{% extends 'client/base_client.html.twig' %}
{% block title %}Offres d'emploi{% endblock %}
{% block nav_offres %}active{% endblock %}

{% block body %}
<div class="pf-hero">
  <div class="pf-hero-bg"></div>
  <div class="pf-hero-grid"></div>
  <div class="pf-hero-inner">
    <div class="pf-hero-badge"><div class="pf-hero-badge-dot"></div>Espace candidat</div>
    <h1>Offres <span>d'emploi</span></h1>
    <p>Découvrez les opportunités qui correspondent à votre profil</p>
  </div>
</div>

<div class="pf-content">
  <div class="pf-section">
    <form method="get" class="filter-form">
        <input type="text" name="search" value="{{ search }}" placeholder="Rechercher une offre..." class="filter-input">
        <select name="domaine" class="filter-select">
            <option value="">Domaine</option>
            {% for d in ['IT','Finance','Marketing','RH','Vente','Production'] %}
                <option value="{{ d }}" {{ domaine == d ? 'selected' : '' }}>{{ d }}</option>
            {% endfor %}
        </select>
        <select name="contrat" class="filter-select">
            <option value="">Contrat</option>
            {% for c in ['CDI','CDD','Stage','Freelance'] %}
                <option value="{{ c }}" {{ contrat == c ? 'selected' : '' }}>{{ c }}</option>
            {% endfor %}
        </select>
        <select name="sort" class="filter-select">
            <option value="">Trier par</option>
            <option value="titre"   {{ sort == 'titre'   ? 'selected' : '' }}>Nom</option>
            <option value="domaine" {{ sort == 'domaine' ? 'selected' : '' }}>Domaine</option>
            <option value="salaire" {{ sort == 'salaire' ? 'selected' : '' }}>Salaire min</option>
        </select>
        <button type="submit" class="btn btn-primary">Rechercher</button>
        <a href="{{ path('offre_list') }}" class="btn btn-secondary">Réinitialiser</a>
    </form>
  </div>

{% if offres is empty %}
    <div class="empty-state">
        <div class="empty-icon">💼</div>
        <p class="empty-title">Aucune offre disponible pour le moment</p>
    </div>
{% else %}

{# ── Detail modal ── #}
<div id="offre-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:9999;align-items:center;justify-content:center;padding:16px" onclick="if(event.target===this)closeModal()">
    <div style="background:#1e1b3a;border:1px solid rgba(255,255,255,0.12);border-radius:18px;padding:28px;max-width:580px;width:100%;max-height:85vh;overflow-y:auto;position:relative">
        <button onclick="closeModal()" style="position:absolute;top:14px;right:16px;background:none;border:none;font-size:20px;cursor:pointer;color:#9999b8;line-height:1">✕</button>
        <div id="modal-badges" style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px"></div>
        <h2 id="modal-title" style="font-size:20px;font-weight:700;color:#fff;margin:0 0 16px"></h2>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:18px" id="modal-meta"></div>
        <h4 style="font-size:11px;font-weight:600;color:#9999b8;text-transform:uppercase;letter-spacing:.07em;margin-bottom:8px">Description</h4>
        <p id="modal-desc" style="color:rgba(255,255,255,0.8);line-height:1.7;font-size:14px;white-space:pre-line;margin:0 0 22px"></p>
        <div id="modal-cta"></div>
    </div>
</div>

<div class="cards-grid">
    {% for offre in offres %}
    <div class="offer-card">
        <div class="card-badges">
            <span class="badge badge-domain">{{ offre.domaine }}</span>
            <span class="badge badge-contrat">{{ offre.typeContrat }}</span>
        </div>
        <h3 class="card-title" style="cursor:pointer" onclick="openModal({{ offre.id }})">{{ offre.titre }}</h3>
        <p class="card-desc">{{ offre.description|slice(0, 120) }}{% if offre.description|length > 120 %}… <button onclick="openModal({{ offre.id }})" style="background:none;border:none;color:#9D6BFF;cursor:pointer;font-size:13px;padding:0">Voir plus</button>{% endif %}</p>
        <div class="card-info-panel">
            <div class="card-info-row">💰 {{ offre.salaireMin }} – {{ offre.salaireMax }} DT</div>
            <div class="card-info-row">📊 Score minimum : {{ offre.scoreMinimum }}%</div>
            <div class="card-info-row">⏱ Durée du test : {{ offre.dureeTestMinutes }} min</div>
        </div>
        <div class="card-actions">
            {% if dejaPostule[offre.id] is defined %}
                <button class="btn btn-applied" disabled>✅ Déjà postulé</button>
            {% else %}
                <a href="{{ path('quiz_start', {id: offre.id}) }}" class="btn btn-postuler">Postuler maintenant</a>
            {% endif %}
        </div>
    </div>
    {% endfor %}
</div>

{# Offre data for modal #}
<script>
const offresData = {
    {% for offre in offres %}
    {{ offre.id }}: {
        titre: {{ offre.titre|json_encode|raw }},
        domaine: {{ offre.domaine|json_encode|raw }},
        contrat: {{ offre.typeContrat|json_encode|raw }},
        description: {{ offre.description|json_encode|raw }},
        salaireMin: {{ offre.salaireMin }},
        salaireMax: {{ offre.salaireMax }},
        scoreMin: {{ offre.scoreMinimum }},
        duree: {{ offre.dureeTestMinutes }},
        dejaPostule: {{ dejaPostule[offre.id] is defined ? 'true' : 'false' }},
        quizUrl: {{ path('quiz_start', {id: offre.id})|json_encode|raw }},
    },
    {% endfor %}
};

function openModal(id) {
    const o = offresData[id];
    if (!o) return;
    document.getElementById('modal-title').textContent = o.titre;
    document.getElementById('modal-badges').innerHTML =
        `<span class="badge badge-domain">${o.domaine}</span><span class="badge badge-contrat">${o.contrat}</span>`;
    document.getElementById('modal-meta').innerHTML = `
        <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:12px">
            <div style="font-size:10px;color:#9999b8;font-weight:600;text-transform:uppercase;margin-bottom:4px">💰 Salaire</div>
            <div style="font-weight:700;color:#fff">${o.salaireMin} – ${o.salaireMax} DT</div>
        </div>
        <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:12px">
            <div style="font-size:10px;color:#9999b8;font-weight:600;text-transform:uppercase;margin-bottom:4px">📊 Score min</div>
            <div style="font-weight:700;color:#fff">${o.scoreMin}%</div>
        </div>
        <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:12px">
            <div style="font-size:10px;color:#9999b8;font-weight:600;text-transform:uppercase;margin-bottom:4px">⏱ Durée test</div>
            <div style="font-weight:700;color:#fff">${o.duree} min</div>
        </div>
        <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:12px">
            <div style="font-size:10px;color:#9999b8;font-weight:600;text-transform:uppercase;margin-bottom:4px">📋 Contrat</div>
            <div style="font-weight:700;color:#fff">${o.contrat}</div>
        </div>`;
    document.getElementById('modal-desc').textContent = o.description;
    document.getElementById('modal-cta').innerHTML = o.dejaPostule
        ? `<button class="btn btn-applied" disabled style="width:100%;justify-content:center">✅ Déjà postulé</button>`
        : `<a href="${o.quizUrl}" class="btn btn-postuler" style="width:100%;text-align:center;display:block">🚀 Postuler maintenant</a>`;
    const modal = document.getElementById('offre-modal');
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
}

function closeModal() {
    document.getElementById('offre-modal').style.display = 'none';
    document.body.style.overflow = '';
}

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>
{% endif %}
</div>{# end pf-content #}
{% endblock %}
