{% extends 'base.html.twig' %}
{% block title %}Fiches de paiement — PathFinder{% endblock %}

{% block body %}

<h1 class="page-title">Fiches de paiement</h1>

<div style="display:flex; gap:10px; margin-bottom:15px">
  <a href="{{ path('fiche_new') }}" class="btn-new">+ Nouvelle Fiche</a>
  <a href="{{ path('fiche_print_all') }}" class="btn-print" target="_blank">🖨 Imprimer tout</a>
</div>

<div class="table-container">
  <table class="pf-table">
    <thead>
      <tr>
        <th>Employé</th>
        <th>Salaire Base</th>
        <th>Date</th>
        <th>Type</th>
        <th>Taxe</th>
        <th>Déduction</th>
        <th>Primes</th>
        <th style="color:#fff">💰 Salaire Final</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      {% for fiche in fiches %}
        <tr class="row-animate">
          <td>{{ fiche.employee.utilisateur.nom }} {{ fiche.employee.utilisateur.prenom }}</td>
          <td>{{ fiche.employee.salaire }} DT</td>
          <td>{{ fiche.datePaiement ? fiche.datePaiement|date('Y-m-d') : '-' }}</td>
          <td>{{ fiche.typePaiement }}</td>
          <td>{{ fiche.montantTaxe }} DT</td>
          <td style="color:#ef4444">- {{ fiche.montantDeduction }} DT</td>
          <td style="color:#22c55e">
            + {{ fiche.primes|reduce((carry, p) => carry + p.montant, 0) }} DT
          </td>
          <td style="font-weight:700; color:#6C63FF">
            {{ fiche.salaireNet }} DT
          </td>
          <td class="actions">
            <a href="{{ path('fiche_edit', {id: fiche.idFichePaiement}) }}" class="btn-edit">Modifier</a>
             <a href="{{ path('prime_new_for_fiche', {id: fiche.idFichePaiement}) }}" class="btn-prime" title="Ajouter une prime">⭐ Prime</a>
            <a href="{{ path('fiche_print_one', {id: fiche.idFichePaiement}) }}" class="btn-print" target="_blank">🖨</a>
            <form method="post" action="{{ path('fiche_delete', {id: fiche.idFichePaiement}) }}" class="inline-form">
              <button type="submit" class="btn-delete" onclick="return confirm('Supprimer ?')">Supprimer</button>
            </form>
          </td>
        </tr>
      {% else %}
        <tr>
          <td colspan="9" class="empty-row">Aucune fiche disponible</td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<style>
.page-title { font-size: 2rem; font-weight: 700; color: #4A4A4A; margin-bottom: 20px; }
.table-container { overflow-x: auto; margin-top: 20px; border-radius: 10px; background: white; padding: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
.pf-table { width: 100%; border-collapse: collapse; font-family: 'Arial', sans-serif; }
.pf-table thead { background: linear-gradient(90deg, #6C63FF, #8A84FF); color: white; }
.pf-table th, .pf-table td { padding: 14px 18px; text-align: left; border-bottom: 1px solid #eee; }
.pf-table tbody tr:nth-child(even) { background-color: #fafafa; }
.pf-table tbody tr:hover { background-color: #f0edff; transition: 0.2s ease-in-out; }
.row-animate { animation: fadeIn 0.4s ease forwards; opacity: 0; }
@keyframes fadeIn { to { opacity: 1; } }
.btn-new { display: inline-block; background-color: #6C63FF; color: white; padding: 10px 18px; text-decoration: none; border-radius: 6px; font-weight: bold; transition: 0.2s; }
.btn-new:hover { background-color: #5a54e6; }
.btn-edit { background-color: #4B8BF5; color: white; padding: 6px 12px; text-decoration: none; border-radius: 4px; font-size: 0.9rem; transition: 0.2s; }
.btn-edit:hover { background-color: #3a78e0; }
.btn-delete { background-color: #FF5C5C; color: white; padding: 6px 12px; border: none; border-radius: 4px; font-size: 0.9rem; cursor: pointer; transition: 0.2s; }
.btn-delete:hover { background-color: #e04a4a; }
.btn-print { background-color: #22c55e; color: white; padding: 6px 12px; text-decoration: none; border-radius: 4px; font-size: 0.9rem; transition: 0.2s; display: inline-block; }
.btn-print:hover { background-color: #16a34a; }
.flash-success { background-color: #DFF2BF; color: #4F8A10; padding: 12px 18px; border-radius: 5px; margin-bottom: 15px; font-weight: bold; }
.empty-row { text-align: center; color: #777; padding: 20px; font-style: italic; }
.inline-form { display: inline; }
.actions { display: flex; gap: 6px; align-items: center; }
.btn-prime { background-color: #f97316; color: white; padding: 6px 12px; text-decoration: none; border-radius: 4px; font-size: 0.9rem; transition: 0.2s; display: inline-block; }
.btn-prime:hover { background-color: #ea6d0e; }
</style>

{% endblock %}