{% extends 'admin_base.html.twig' %}
{% block title %}Fiches de Paie — PathFinder{% endblock %}
{% block page_icon %}💶{% endblock %}
{% block page_title %}Gestion des Fiches de Paie{% endblock %}
{% block topbar_actions %}
    <a href="{{ path('fiche_print_all') }}" class="admin-tool-btn" target="_blank">🖨 Imprimer tout</a>
    <a href="{{ path('fiche_new') }}" class="btn btn-primary" style="background:linear-gradient(135deg,#6C63FF,#9D6BFF);border:none;border-radius:10px;padding:10px 20px;font-weight:600;text-decoration:none;color:#fff;">+ Nouvelle Fiche</a>
{% endblock %}

{% block body %}
<div class="admin-table-section">
    <div class="admin-table-header">
        <div class="admin-table-title">
            Liste des Fiches
            <span class="admin-count-badge">{{ fiches|length }}</span>
        </div>
        <div class="admin-table-actions">
            <input type="text" id="searchInput" placeholder="Rechercher par nom..." class="admin-search-input" oninput="filterTable()">
            <select id="sortSelect" class="admin-search-input" style="width:auto" onchange="sortTable()">
                <option value="">⇅ Trier par...</option>
                <option value="0">Nom A→Z</option>
                <option value="0-desc">Nom Z→A</option>
                <option value="1">Salaire ↑</option>
                <option value="1-desc">Salaire ↓</option>
                <option value="7">Salaire Final ↑</option>
                <option value="7-desc">Salaire Final ↓</option>
            </select>
            <button onclick="resetTable()" class="admin-tool-btn">✕ Reset</button>
        </div>
    </div>
    <table class="admin-table" id="fichesTable">
        <thead><tr>
            <th>Employé</th><th>Salaire Base</th><th>Date</th><th>Type</th>
            <th>Taxe</th><th>Déduction</th><th>Primes</th><th>💰 Salaire Final</th><th style="text-align:right">Actions</th>
        </tr></thead>
        <tbody>
        {% for fiche in fiches %}
        <tr class="row-animate" onclick="window.location='{{ path('fiche_show', {id: fiche.idFichePaiement}) }}'" style="cursor:pointer">
            <td class="admin-table-name">{{ fiche.employee.utilisateur.nom }} {{ fiche.employee.utilisateur.prenom }}</td>
            <td>{{ fiche.employee.salaire }} DT</td>
            <td class="admin-table-muted">{{ fiche.datePaiement ? fiche.datePaiement|date('d/m/Y') : '—' }}</td>
            <td><span class="admin-badge admin-badge-blue">{{ fiche.typePaiement }}</span></td>
            <td class="admin-table-muted">{{ fiche.montantTaxe }} DT</td>
            <td style="color:#dc2626">- {{ fiche.montantDeduction }} DT</td>
            <td style="color:#16a34a">+ {{ fiche.primes|reduce((carry, p) => carry + p.montant, 0) }} DT</td>
            <td style="font-weight:700;color:#6C63FF">{{ fiche.salaireNet }} DT</td>
            <td onclick="event.stopPropagation()">
                <div class="admin-row-actions" style="justify-content:flex-end">
                    <a href="{{ path('fiche_edit', {id: fiche.idFichePaiement}) }}" class="admin-action-btn">✏️</a>
                    <a href="{{ path('prime_new_for_fiche', {id: fiche.idFichePaiement}) }}" class="admin-action-btn" style="color:#d97706">⭐</a>
                    <a href="{{ path('fiche_print_one', {id: fiche.idFichePaiement}) }}" class="admin-action-btn" target="_blank">🖨</a>
                    <form method="post" action="{{ path('fiche_delete', {id: fiche.idFichePaiement}) }}" onsubmit="return confirm('Supprimer ?')" style="display:inline">
                        <button type="submit" class="admin-action-btn admin-action-delete">🗑</button>
                    </form>
                </div>
            </td>
        </tr>
        {% else %}
        <tr><td colspan="9" style="text-align:center;color:#9999b8;padding:2rem">Aucune fiche disponible</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

{% block javascripts %}
<script>
function filterTable() {
    const q = document.getElementById('searchInput').value.toLowerCase();
    document.querySelectorAll('#fichesTable tbody tr.row-animate').forEach(r => {
        r.style.display = r.cells[0].innerText.toLowerCase().includes(q) ? '' : 'none';
    });
}
function sortTable() {
    const val = document.getElementById('sortSelect').value;
    if (!val) return;
    const [col, dir] = val.split('-');
    const tbody = document.querySelector('#fichesTable tbody');
    const rows = Array.from(tbody.querySelectorAll('tr.row-animate'));
    rows.sort((a, b) => {
        let av = a.cells[parseInt(col)]?.innerText.replace(/[^0-9.]/g,'') || '';
        let bv = b.cells[parseInt(col)]?.innerText.replace(/[^0-9.]/g,'') || '';
        const an = parseFloat(av), bn = parseFloat(bv);
        if (!isNaN(an) && !isNaN(bn)) return dir === 'desc' ? bn - an : an - bn;
        return dir === 'desc' ? bv.localeCompare(av) : av.localeCompare(bv);
    });
    rows.forEach(r => tbody.appendChild(r));
}
function resetTable() {
    document.getElementById('searchInput').value = '';
    document.getElementById('sortSelect').value = '';
    document.querySelectorAll('#fichesTable tbody tr.row-animate').forEach(r => r.style.display = '');
}
</script>
{% endblock %}
