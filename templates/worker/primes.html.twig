{% extends 'worker/base_worker.html.twig' %}
{% block title %}Mes Primes — PathFinder{% endblock %}
{% block nav_primes %}active{% endblock %}

{% block body %}
<div class="pf-hero">
  <div class="pf-hero-bg"></div>
  <div class="pf-hero-grid"></div>
  <div class="pf-hero-inner">
    <div class="pf-hero-badge"><div class="pf-hero-badge-dot"></div>Espace Employé</div>
    <h1>Mes <span>Primes</span></h1>
    <p>Consultez toutes vos primes et bonus attribués.</p>
  </div>
</div>

<div class="pf-content">

  {% set totalPrimes = 0 %}
  {% for prime in primes %}{% set totalPrimes = totalPrimes + prime.montant %}{% endfor %}

  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:2rem">
    <div class="pf-section" style="padding:1.5rem;text-align:center">
      <div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px">Nombre de primes</div>
      <div style="font-size:2rem;font-weight:700;color:var(--stat-num)">{{ primes|length }}</div>
    </div>
    <div class="pf-section" style="padding:1.5rem;text-align:center">
      <div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px">Total reçu</div>
      <div style="font-size:2rem;font-weight:700;color:#22c55e">{{ totalPrimes }} <span style="font-size:1rem;color:var(--text-muted)">DT</span></div>
    </div>
    <div class="pf-section" style="padding:1.5rem;text-align:center">
      <div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px">Moyenne</div>
      <div style="font-size:2rem;font-weight:700;color:var(--primary)">{{ primes|length > 0 ? (totalPrimes / primes|length)|round : 0 }} <span style="font-size:1rem;color:var(--text-muted)">DT</span></div>
    </div>
  </div>

  <div class="pf-section">
    <div class="pf-section-label">Historique</div>
    <h2>Mes primes</h2>
    <div class="pf-divider"></div>

    {% if primes is empty %}
      <div style="text-align:center;padding:3rem;color:var(--text-muted)">
        <div style="font-size:3rem;margin-bottom:1rem">🏆</div>
        <p>Aucune prime disponible pour le moment.</p>
      </div>
    {% else %}
    <table style="width:100%;border-collapse:collapse">
      <thead>
        <tr style="border-bottom:.5px solid var(--border)">
          <th style="padding:12px 10px;text-align:left;color:var(--text-muted);font-size:11px;letter-spacing:.08em;text-transform:uppercase">Libellé</th>
          <th style="padding:12px 10px;text-align:left;color:var(--text-muted);font-size:11px;letter-spacing:.08em;text-transform:uppercase">Type</th>
          <th style="padding:12px 10px;text-align:left;color:var(--text-muted);font-size:11px;letter-spacing:.08em;text-transform:uppercase">Montant</th>
          <th style="padding:12px 10px;text-align:left;color:var(--text-muted);font-size:11px;letter-spacing:.08em;text-transform:uppercase">Date</th>
        </tr>
      </thead>
      <tbody>
        {% for prime in primes %}
        <tr style="border-bottom:.5px solid var(--border);transition:background .15s"
            onmouseover="this.style.background='var(--surface-hover)'"
            onmouseout="this.style.background='transparent'">
          <td style="padding:14px 10px;color:var(--text);font-weight:500">{{ prime.libelle }}</td>
          <td style="padding:14px 10px">
            <span style="background:rgba(108,99,255,.12);border:.5px solid rgba(108,99,255,.3);color:var(--primary);padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600">{{ prime.typePrime }}</span>
          </td>
          <td style="padding:14px 10px;color:#22c55e;font-weight:700;font-size:15px">+ {{ prime.montant }} DT</td>
          <td style="padding:14px 10px;color:var(--text-muted)">{{ prime.dateAttribution ? prime.dateAttribution|date('d/m/Y') : '—' }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% endif %}
  </div>
</div>
{% endblock %}
