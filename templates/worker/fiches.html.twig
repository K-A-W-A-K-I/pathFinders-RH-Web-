{% extends 'base_public.html.twig' %}

{% block title %}Mes Fiches — PathFinder{% endblock %}

{% block nav_fiches %}active{% endblock %}

{% block content %}

<div class="pf-hero">
  <div class="pf-hero-bg"></div>
  <div class="pf-hero-grid"></div>
  <div class="pf-hero-inner">
    <div class="pf-hero-badge">
      <div class="pf-hero-badge-dot"></div>
      Espace Employé
    </div>
    <h1>Mes Fiches de<br><span>Paiement</span></h1>
    <p>Consultez vos fiches de paiement et le détail de votre rémunération.</p>
  </div>
</div>

<div class="pf-content">
  <div class="pf-section">
    <div class="pf-section-label">Fiches de Paiement</div>
    <h2>Historique de vos fiches</h2>
    <div class="pf-divider"></div>

    <table style="width:100%;border-collapse:collapse;margin-top:1rem;">
      <thead>
        <tr style="border-bottom:1px solid var(--border);">
          <th style="padding:12px 10px;text-align:left;color:var(--text-muted);font-size:11px;letter-spacing:.08em;text-transform:uppercase;">Employé</th>
          <th style="padding:12px 10px;text-align:left;color:var(--text-muted);font-size:11px;letter-spacing:.08em;text-transform:uppercase;">Date</th>
          <th style="padding:12px 10px;text-align:left;color:var(--text-muted);font-size:11px;letter-spacing:.08em;text-transform:uppercase;">Type</th>
          <th style="padding:12px 10px;text-align:left;color:var(--text-muted);font-size:11px;letter-spacing:.08em;text-transform:uppercase;">Salaire Base</th>
          <th style="padding:12px 10px;text-align:left;color:var(--text-muted);font-size:11px;letter-spacing:.08em;text-transform:uppercase;">Taxe</th>
          <th style="padding:12px 10px;text-align:left;color:var(--text-muted);font-size:11px;letter-spacing:.08em;text-transform:uppercase;">Déduction</th>
          <th style="padding:12px 10px;text-align:left;color:var(--text-muted);font-size:11px;letter-spacing:.08em;text-transform:uppercase;">Primes</th>
          <th style="padding:12px 10px;text-align:left;color:var(--primary);font-size:11px;letter-spacing:.08em;text-transform:uppercase;">💰 Salaire Final</th>
        </tr>
      </thead>
      <tbody>
        {% for fiche in fiches %}
        <tr style="border-bottom:.5px solid var(--border);transition:background .15s;"
            onmouseover="this.style.background='var(--surface-hover)'"
            onmouseout="this.style.background='transparent'">
          <td style="padding:14px 10px;color:var(--text);font-weight:500;">
            {{ fiche.employee.utilisateur.nom }} {{ fiche.employee.utilisateur.prenom }}
          </td>
          <td style="padding:14px 10px;color:var(--text-muted);">
            {{ fiche.datePaiement ? fiche.datePaiement|date('d/m/Y') : '—' }}
          </td>
          <td style="padding:14px 10px;">
            <span style="background:rgba(108,99,255,.12);border:.5px solid rgba(108,99,255,.3);color:var(--primary);padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600;">
              {{ fiche.typePaiement }}
            </span>
          </td>
          <td style="padding:14px 10px;color:var(--text);">
            {{ fiche.employee.salaire }} DT
          </td>
          <td style="padding:14px 10px;color:var(--red);">
            - {{ fiche.montantTaxe }} DT
          </td>
          <td style="padding:14px 10px;color:var(--red);">
            - {{ fiche.montantDeduction|abs }} DT
          </td>
          <td style="padding:14px 10px;color:#22c55e;">
            + {{ fiche.primes|reduce((carry, p) => carry + p.montant, 0) }} DT
          </td>
          <td style="padding:14px 10px;font-weight:700;color:var(--primary);font-size:1rem;">
            {{ fiche.salaireNet }} DT
          </td>
        </tr>
        {% else %}
        <tr>
          <td colspan="8" style="padding:40px;text-align:center;color:var(--text-dim);">
            Aucune fiche disponible.
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  {# ── STATS ── #}
  <div class="pf-stats">
    <div class="pf-stat">
      <div class="pf-stat-num">{{ fiches|length }}<span></span></div>
      <div class="pf-stat-label">Fiches au total</div>
    </div>
    <div class="pf-stat">
      <div class="pf-stat-num">
        {% set totalDed = 0 %}
        {% for fiche in fiches %}
          {% set totalDed = totalDed + fiche.montantDeduction|abs %}
        {% endfor %}
        {{ totalDed }}<span> DT</span>
      </div>
      <div class="pf-stat-label">Total déductions</div>
    </div>
    <div class="pf-stat">
      <div class="pf-stat-num">
        {% set totalTaxe = 0 %}
        {% for fiche in fiches %}
          {% set totalTaxe = totalTaxe + fiche.montantTaxe %}
        {% endfor %}
        {{ totalTaxe }}<span> DT</span>
      </div>
      <div class="pf-stat-label">Total taxes</div>
    </div>
    <div class="pf-stat">
      <div class="pf-stat-num">
        {% set totalNet = 0 %}
        {% for fiche in fiches %}
          {% set totalNet = totalNet + fiche.salaireNet %}
        {% endfor %}
        {{ totalNet }}<span> DT</span>
      </div>
      <div class="pf-stat-label">Total salaire net</div>
    </div>
  </div>

</div>
{% endblock %}