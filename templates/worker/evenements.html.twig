{% extends 'worker/base_worker.html.twig' %}
{% block title %}Événements — PathFinder{% endblock %}
{% block nav_evenements %}active{% endblock %}

{% block stylesheets %}
<style>
    .evl-body{max-width:1160px;margin:0 auto;padding:2rem 2.5rem 5rem}
    .evl-filter-wrap{background:var(--surface);border:.5px solid var(--border);border-radius:22px;padding:22px 26px;margin-bottom:1.8rem;box-shadow:0 4px 24px rgba(108,99,255,.07)}
    .evl-filter-top{display:flex;gap:14px;align-items:flex-end;flex-wrap:wrap}
    .evl-filter-field{display:flex;flex-direction:column;flex:1;min-width:180px}
    .evl-filter-label{font-size:10.5px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--primary);margin-bottom:8px;font-family:'Sora',sans-serif}
    .evl-input-wrap{position:relative}
    .evl-input{width:100%;background:var(--surface);border:.5px solid var(--border);border-radius:12px;padding:10px 14px;font-size:13.5px;font-family:'DM Sans',sans-serif;color:var(--text);outline:none}
    .evl-select{width:100%;background:var(--surface);border:.5px solid var(--border);border-radius:12px;padding:10px 14px;font-size:13.5px;font-family:'DM Sans',sans-serif;color:var(--text);outline:none;cursor:pointer}
    .evl-filter-btns{display:flex;gap:8px}
    .evl-btn-filter{background:linear-gradient(135deg,var(--primary),var(--accent));color:#fff;border:none;padding:11px 22px;border-radius:12px;font-size:13px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:7px}
    .evl-btn-reset{background:var(--surface);color:var(--text-muted);border:.5px solid var(--border);padding:11px 18px;border-radius:12px;font-size:13px;text-decoration:none;display:inline-flex;align-items:center;gap:6px}
    .evl-results-count{font-size:13px;color:var(--text-muted);margin-bottom:1.2rem}
    .evl-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(330px,1fr));gap:22px}
    .evl-card{background:var(--surface);border:.5px solid var(--border);border-radius:22px;overflow:hidden;display:flex;flex-direction:column;transition:transform .25s,border-color .25s,box-shadow .25s}
    .evl-card:hover{transform:translateY(-6px);border-color:rgba(108,99,255,.3);box-shadow:0 16px 44px rgba(108,99,255,.13)}
    .evl-card-stripe{height:3px;background:linear-gradient(90deg,var(--primary),var(--accent));opacity:0;transition:opacity .25s}
    .evl-card:hover .evl-card-stripe{opacity:1}
    .evl-card-media{height:178px;background:linear-gradient(135deg,#1a1d2e,#3d3a8e,#6C63FF);position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
    .evl-card-media img{width:100%;height:100%;object-fit:cover}
    .evl-card-media-emoji{font-size:52px;opacity:.5}
    .evl-card-fav-zone{position:absolute;top:12px;right:12px;z-index:2}
    .evl-fav-btn{width:36px;height:36px;border-radius:50%;border:none;cursor:pointer;font-size:14px;background:rgba(255,255,255,.15);backdrop-filter:blur(10px);color:rgba(255,255,255,.85);display:flex;align-items:center;justify-content:center;transition:all .2s}
    .evl-fav-btn.is-active{background:linear-gradient(135deg,#f59e0b,#ea580c);color:#fff}
    .evl-card-body{padding:20px 22px 22px;flex:1;display:flex;flex-direction:column}
    .evl-card-badges{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px}
    .evl-badge{display:inline-flex;align-items:center;font-size:10.5px;font-weight:700;padding:3px 10px;border-radius:100px;font-family:'Sora',sans-serif}
    .evl-badge-cat{background:rgba(108,99,255,.15);color:var(--primary)}
    .evl-badge-actif{background:#dcfce7;color:#16a34a}
    .evl-badge-complet{background:#fef3c7;color:#d97706}
    .evl-badge-annule{background:#fee2e2;color:#dc2626}
    .evl-card-title{font-family:'Sora',sans-serif;font-size:15.5px;font-weight:700;color:var(--text);margin-bottom:9px}
    .evl-card-desc{font-size:13px;line-height:1.65;color:var(--text-muted);flex:1;margin-bottom:16px}
    .evl-card-meta{background:var(--surface);border:.5px solid var(--border);border-radius:12px;padding:10px 13px;margin-bottom:16px;display:grid;gap:6px}
    .evl-meta-line{font-size:12.5px;color:var(--text-muted);display:flex;align-items:center;gap:8px}
    .evl-meta-line i{color:var(--primary);font-size:12px;width:14px;text-align:center}
    .evl-free-badge{color:#16a34a;font-weight:700}
    .evl-card-actions{display:flex;gap:9px}
    .evl-btn-detail{flex:1;border:none;border-radius:12px;padding:11px 12px;background:rgba(108,99,255,.15);color:var(--primary);font-size:13px;font-weight:600;font-family:'DM Sans',sans-serif;text-decoration:none;display:inline-flex;align-items:center;justify-content:center;gap:6px;cursor:pointer;transition:all .2s}
    .evl-btn-detail:hover{background:var(--primary);color:#fff}
    .evl-btn-register{flex:1;border:none;border-radius:12px;padding:11px 12px;background:linear-gradient(135deg,var(--primary),var(--accent));color:#fff;font-size:13px;font-weight:600;font-family:'DM Sans',sans-serif;display:inline-flex;align-items:center;justify-content:center;gap:6px;cursor:pointer;box-shadow:0 4px 14px rgba(108,99,255,.28)}
    .evl-btn-register:disabled{background:var(--border);color:var(--text-muted);box-shadow:none;cursor:not-allowed}
    @keyframes evlFadeUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
</style>
{% endblock %}

{% block body %}
<div class="pf-hero">
  <div class="pf-hero-bg"></div>
  <div class="pf-hero-grid"></div>
  <div class="pf-hero-inner">
    <div class="pf-hero-badge"><div class="pf-hero-badge-dot"></div>Espace Employé</div>
    <h1>Explorez les <span>événements</span></h1>
    <p>Découvrez les événements actifs et inscrivez-vous directement depuis votre espace.</p>
  </div>
</div>

<div class="evl-body">
    <form method="get" action="{{ path('worker_evenements') }}" class="evl-filter-wrap" id="evlFilterForm">
        <div class="evl-filter-top">
            <div class="evl-filter-field">
                <div class="evl-filter-label">Recherche</div>
                <div class="evl-input-wrap">
                    <input id="evlSearch" type="text" name="search" value="{{ search }}" placeholder="Titre, lieu…" class="evl-input">
                </div>
            </div>
            <div class="evl-filter-field" style="max-width:220px">
                <div class="evl-filter-label">Catégorie</div>
                <select id="evlCategory" name="categorie" class="evl-select">
                    <option value="">Toutes</option>
                    {% for cat in categories %}
                        <option value="{{ cat.id }}" {% if categorieId == cat.id %}selected{% endif %}>{{ cat.nomCategorie }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="evl-filter-btns">
                <button type="submit" class="evl-btn-filter"><i class="bi bi-funnel-fill"></i> Filtrer</button>
                <a href="{{ path('worker_evenements') }}" class="evl-btn-reset"><i class="bi bi-x-circle"></i> Reset</a>
            </div>
        </div>
    </form>

    <div class="evl-results-count"><strong>{{ evenements|length }}</strong> événement{{ evenements|length > 1 ? 's' : '' }}</div>

    {% if evenements is empty %}
        <div style="text-align:center;padding:4rem;color:var(--text-muted)">
            <div style="font-size:3rem;margin-bottom:1rem">📅</div>
            <p>Aucun événement trouvé.</p>
        </div>
    {% else %}
    <div class="evl-grid">
        {% for evenement in evenements %}
        <article class="evl-card">
            <div class="evl-card-stripe"></div>
            <div class="evl-card-media">
                {% if evenement.imagePath %}
                    <img src="{{ asset(evenement.imagePath) }}" alt="{{ evenement.titre }}">
                {% else %}
                    <div class="evl-card-media-emoji">🎪</div>
                {% endif %}
                <div class="evl-card-fav-zone">
                    <form method="post" action="{{ path('user_evenement_toggle_favorite', {id: evenement.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('favorite_evenement_' ~ evenement.id) }}">
                        <button type="button" class="evl-fav-btn {{ evenement.id in favoriteIds ? 'is-active' : '' }}"
                            onclick="openUserConfirm(this)"
                            data-confirm-title="{{ evenement.id in favoriteIds ? 'Retirer des favoris ?' : 'Ajouter aux favoris ?' }}"
                            data-confirm-text="{{ evenement.id in favoriteIds ? 'Retirer cet événement de vos favoris.' : 'Ajouter cet événement à vos favoris.' }}"
                            data-confirm-icon="bi-star-fill" data-confirm-button="Confirmer">
                            <i class="bi {{ evenement.id in favoriteIds ? 'bi-star-fill' : 'bi-star' }}"></i>
                        </button>
                    </form>
                </div>
            </div>
            <div class="evl-card-body">
                <div class="evl-card-badges">
                    {% if evenement.categorie %}<span class="evl-badge evl-badge-cat">{{ evenement.categorie.nomCategorie }}</span>{% endif %}
                    <span class="evl-badge evl-badge-{{ evenement.statut|lower }}">{{ evenement.statut }}</span>
                </div>
                <h3 class="evl-card-title">{{ evenement.titre }}</h3>
                <p class="evl-card-desc">{{ evenement.description ? evenement.description|slice(0,115) ~ '…' : 'Aucune description.' }}</p>
                <div class="evl-card-meta">
                    <div class="evl-meta-line"><i class="bi bi-calendar3"></i> {{ evenement.dateDebut|date('d/m/Y') }} → {{ evenement.dateFin|date('d/m/Y') }}</div>
                    <div class="evl-meta-line"><i class="bi bi-geo-alt-fill"></i> {{ evenement.lieu ?: 'Lieu non précisé' }}</div>
                    <div class="evl-meta-line">
                        <i class="bi bi-ticket-perforated-fill"></i>
                        {{ evenement.placesRestantesCalculated }} place(s) ·
                        {% if evenement.prix and evenement.prix > 0 %}{{ evenement.prix }} TND{% else %}<span class="evl-free-badge">Gratuit</span>{% endif %}
                    </div>
                </div>
                <div class="evl-card-actions">
                    <a href="{{ path('user_evenement_show', {id: evenement.id}) }}" class="evl-btn-detail"><i class="bi bi-eye"></i> Détails</a>
                    <form method="post" action="{{ path('user_evenement_register', {id: evenement.id}) }}" style="flex:1;display:flex">
                        <input type="hidden" name="_token" value="{{ csrf_token('register_evenement_' ~ evenement.id) }}">
                        <button type="button" class="evl-btn-register" style="flex:1"
                            {% if evenement.id in registeredIds or evenement.isFull %}disabled{% endif %}
                            onclick="openUserConfirm(this)"
                            data-confirm-title="Confirmer l'inscription ?"
                            data-confirm-text="Vous allez vous inscrire à &quot;{{ evenement.titre|e('html_attr') }}&quot;."
                            data-confirm-icon="bi-person-check-fill" data-confirm-button="Confirmer">
                            {% if evenement.id in registeredIds %}<i class="bi bi-check-circle-fill"></i> Inscrit
                            {% elseif evenement.isFull %}<i class="bi bi-x-circle"></i> Complet
                            {% else %}<i class="bi bi-person-plus-fill"></i> S'inscrire{% endif %}
                        </button>
                    </form>
                </div>
            </div>
        </article>
        {% endfor %}
    </div>
    {% endif %}
</div>

{# Confirm modal #}
<div id="userConfirmModal" style="display:none;position:fixed;inset:0;z-index:999999;align-items:center;justify-content:center;">
    <div id="pfModalBackdrop" style="position:fixed;inset:0;background:rgba(15,23,42,0.55);backdrop-filter:blur(4px);"></div>
    <div style="position:relative;z-index:1000000;background:white;border-radius:24px;max-width:440px;width:90%;padding:32px 28px;text-align:center;box-shadow:0 26px 70px rgba(15,23,42,0.22);">
        <div id="userConfirmIcon" style="width:64px;height:64px;margin:0 auto 18px;border-radius:20px;display:flex;align-items:center;justify-content:center;font-size:28px;background:linear-gradient(135deg,#eef2ff,#ddd6fe);color:#2729aa;"><i class="bi bi-star-fill"></i></div>
        <h5 id="userConfirmTitle" style="font-size:20px;font-weight:800;color:#010204;margin:0 0 8px;"></h5>
        <p id="userConfirmText" style="font-size:13px;color:#64748b;line-height:1.6;margin:0 0 22px;"></p>
        <div style="display:flex;justify-content:center;gap:10px;">
            <button type="button" id="pfModalCancel" style="border:none;border-radius:10px;padding:11px 22px;font-size:13px;font-weight:700;cursor:pointer;background:#eef2ff;color:#2729aa;">Annuler</button>
            <button type="button" id="userConfirmSubmit" style="border:none;border-radius:10px;padding:11px 22px;font-size:13px;font-weight:700;cursor:pointer;background:#2729aa;color:white;">Confirmer</button>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
let _pfPendingForm = null;
function openUserConfirm(button) {
    _pfPendingForm = button.closest('form');
    document.getElementById('userConfirmTitle').textContent = button.dataset.confirmTitle || 'Confirmation';
    document.getElementById('userConfirmText').innerHTML = button.dataset.confirmText || '';
    document.getElementById('userConfirmModal').style.display = 'flex';
}
document.getElementById('pfModalBackdrop').addEventListener('click', () => document.getElementById('userConfirmModal').style.display = 'none');
document.getElementById('pfModalCancel').addEventListener('click', () => document.getElementById('userConfirmModal').style.display = 'none');
document.getElementById('userConfirmSubmit').addEventListener('click', () => { if (_pfPendingForm) _pfPendingForm.submit(); });
let evlDebounce;
document.getElementById('evlSearch')?.addEventListener('input', function() {
    clearTimeout(evlDebounce);
    evlDebounce = setTimeout(() => document.getElementById('evlFilterForm').submit(), 320);
});
document.getElementById('evlCategory')?.addEventListener('change', () => document.getElementById('evlFilterForm').submit());
</script>
{% endblock %}
