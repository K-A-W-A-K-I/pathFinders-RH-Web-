{% extends 'base_events.html.twig' %}

{% block title %}{{ evenement.titre }}{% endblock %}
{% block page_title %}{{ evenement.titre }}{% endblock %}
{% block page_subtitle %}Détail de l'événement{% endblock %}

{% block body %}

{# ── Back + Actions bar ── #}
<div class="d-flex align-items-center justify-content-between mb-4">
    <a href="{{ path('evenement_index') }}" class="btn-back-pf">
        <i class="bi bi-arrow-left"></i> Retour à la liste
    </a>
    <div class="d-flex gap-2">
        <a href="{{ path('evenement_edit', {id: evenement.id}) }}" class="btn-edit-pf">
            <i class="bi bi-pencil"></i> Modifier
        </a>
        <button class="btn-delete-pf" onclick="confirmDelete('{{ path('evenement_delete', {id: evenement.id}) }}', '{{ csrf_token('delete_evenement_' ~ evenement.id) }}', '{{ evenement.titre|e('js') }}')">
            <i class="bi bi-trash"></i> Supprimer
        </button>
    </div>
</div>

{# ── Detail header card ── #}
<div class="info-card mb-4">
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div>
            <h2 class="detail-title mb-2">{{ evenement.titre }}</h2>
            <div class="d-flex flex-wrap gap-2">
                {% if evenement.categorie %}
                    <span class="tag tag-categorie">
                        <i class="bi bi-tag me-1"></i>{{ evenement.categorie.nomCategorie }}
                    </span>
                {% endif %}
                <span class="tag tag-type">
                    <i class="bi bi-briefcase me-1"></i>{{ evenement.typeEvenement }}
                </span>
                <span class="tag {{ evenement.statutBadgeClass }}">
                    {% if evenement.statut == 'Actif' %}✓
                    {% elseif evenement.statut == 'Complet' %}⬤
                    {% elseif evenement.statut == 'Annulé' %}✕
                    {% else %}⏹{% endif %}
                    {{ evenement.statut }}
                </span>
            </div>
        </div>
        <div style="font-size:12px;color:var(--clr-muted);">
            <i class="bi bi-clock me-1"></i>
            Créé le {{ evenement.dateCreation ? evenement.dateCreation|date('d/m/Y à H:i') : '—' }}
        </div>
    </div>
</div>

{# ── Info cards grid ── #}
<div class="row g-3 mb-4">

    <div class="col-6 col-md-3">
        <div class="info-card h-100">
            <div class="info-card-label"><i class="bi bi-calendar-event me-1"></i>Date de début</div>
            <div class="info-card-value">{{ evenement.dateDebut|date('d/m/Y') }}</div>
        </div>
    </div>

    <div class="col-6 col-md-3">
        <div class="info-card h-100">
            <div class="info-card-label"><i class="bi bi-calendar-check me-1"></i>Date de fin</div>
            <div class="info-card-value">{{ evenement.dateFin|date('d/m/Y') }}</div>
            <div style="font-size:11px;color:var(--clr-muted);margin-top:4px;">
                {{ evenement.dureeJours }} jour{{ evenement.dureeJours != 1 ? 's' : '' }}
            </div>
        </div>
    </div>

    <div class="col-6 col-md-3">
        <div class="info-card h-100">
            <div class="info-card-label"><i class="bi bi-geo-alt me-1"></i>Lieu</div>
            <div class="info-card-value">{{ evenement.lieu ?? '—' }}</div>
        </div>
    </div>

    <div class="col-6 col-md-3">
        <div class="info-card h-100">
            <div class="info-card-label"><i class="bi bi-cash me-1"></i>Prix</div>
            {% if evenement.prix and evenement.prix > 0 %}
                <div class="info-card-value-price">{{ evenement.prix }} <small style="font-size:13px;">TND</small></div>
            {% else %}
                <div class="info-card-value" style="color:var(--clr-success);">Gratuit</div>
            {% endif %}
        </div>
    </div>

</div>

{# ── Capacity card ── #}
<div class="row g-3 mb-4">

    <div class="col-md-4">
        <div class="info-card h-100">
            <div class="info-card-label"><i class="bi bi-people me-1"></i>Capacité maximale</div>
            <div class="info-card-value-big">{{ evenement.capaciteMax }}</div>
            <div style="font-size:12px;color:var(--clr-muted);margin-top:4px;">participants maximum</div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="info-card h-100">
            <div class="info-card-label"><i class="bi bi-person-check me-1"></i>Places réservées</div>
            <div class="info-card-value-big" style="color:var(--clr-lavender);">{{ evenement.placesReservees }}</div>
            <div style="font-size:12px;color:var(--clr-muted);margin-top:4px;">inscriptions enregistrées</div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="info-card h-100">
            <div class="info-card-label"><i class="bi bi-ticket me-1"></i>Places restantes</div>
            <div class="info-card-value-big" style="color:{% if evenement.full %}var(--clr-danger){% else %}var(--clr-success){% endif %};">
                {{ evenement.placesRestantesCalculated }}
            </div>
            {# Progress bar #}
            {% set pct = evenement.capaciteMax > 0 ? (evenement.placesReservees / evenement.capaciteMax * 100) : 0 %}
            <div class="capacity-bar mt-2" style="width:100%;height:8px;">
                <div class="capacity-fill {% if pct >= 100 %}fill-red{% elseif pct >= 75 %}fill-amber{% else %}fill-green{% endif %}"
                     style="width:{{ pct > 100 ? 100 : pct }}%"></div>
            </div>
            <div style="font-size:11px;color:var(--clr-muted);margin-top:4px;">
                {{ pct|round }}% occupé
            </div>
        </div>
    </div>

</div>

{# ── Description ── #}
{% if evenement.description %}
<div class="info-card mb-4">
    <div class="info-card-label mb-2"><i class="bi bi-text-paragraph me-1"></i>Description</div>
    <p style="font-size:14px;color:var(--clr-navy);line-height:1.7;margin:0;">
        {{ evenement.description|nl2br }}
    </p>
</div>
{% endif %}

{# ── Image preview ── #}
{% if evenement.imagePath %}
<div class="info-card mb-4">
    <div class="info-card-label mb-2"><i class="bi bi-image me-1"></i>Image de l'événement</div>
    <div style="background:var(--clr-bg);border-radius:8px;padding:12px;text-align:center;">
        <img src="{{ asset(evenement.imagePath) }}"
             alt="{{ evenement.titre }}"
             style="max-width:100%;max-height:320px;border-radius:8px;object-fit:cover;"
             onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
        <div style="display:none;align-items:center;justify-content:center;height:120px;color:var(--clr-muted);font-size:13px;">
            <i class="bi bi-image me-2"></i> Image non disponible
        </div>
        <div style="font-size:11px;color:var(--clr-muted);margin-top:8px;word-break:break-all;">
            {{ evenement.imagePath }}
        </div>
    </div>
</div>
{% endif %}

{# ══ DELETE MODAL ══ #}
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:420px;">
        <div class="modal-content" style="border-radius:14px;border:none;box-shadow:0 20px 60px rgba(0,0,0,0.15);">
            <div class="modal-body p-4 text-center">
                <div style="width:56px;height:56px;background:#fee2e2;border-radius:50%;
                            display:flex;align-items:center;justify-content:center;
                            font-size:24px;margin:0 auto 16px;">🗑️</div>
                <h5 style="font-weight:700;color:var(--clr-dark);margin-bottom:8px;">Supprimer l'événement ?</h5>
                <p style="font-size:13px;color:var(--clr-muted);margin-bottom:20px;" id="deleteModalText"></p>
                <div class="d-flex gap-2 justify-content-center">
                    <button class="btn-back-pf" style="border:1px solid var(--clr-border);" data-bs-dismiss="modal">
                        Annuler
                    </button>
                    <form id="deleteForm" method="POST">
                        <input type="hidden" name="_token" id="deleteToken">
                        <button type="submit" class="btn-delete-pf">
                            <i class="bi bi-trash"></i> Supprimer définitivement
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
function confirmDelete(url, token, titre) {
    document.getElementById('deleteModalText').textContent =
        'Cette action est irréversible. L\'événement « ' + titre + ' » sera définitivement supprimé.';
    document.getElementById('deleteForm').action = url;
    document.getElementById('deleteToken').value = token;
    new bootstrap.Modal(document.getElementById('deleteModal')).show();
}
</script>
{% endblock %}
