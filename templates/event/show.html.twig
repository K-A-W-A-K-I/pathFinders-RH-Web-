{% extends 'admin_base.html.twig' %}
{% block title %}{{ evenement.titre }}{% endblock %}
{% block page_icon %}📅{% endblock %}
{% block page_title %}{{ evenement.titre }}{% endblock %}
{% block topbar_actions %}
    <a href="{{ path('evenement_edit', {id: evenement.id}) }}" class="admin-tool-btn">✏️ Modifier</a>
    <form method="post" action="{{ path('evenement_delete', {id: evenement.id}) }}" onsubmit="return confirm('Supprimer cet événement ?')" style="display:inline">
        <input type="hidden" name="_token" value="{{ csrf_token('delete_evenement_' ~ evenement.id) }}">
        <button type="submit" class="admin-action-btn admin-action-delete">🗑 Supprimer</button>
    </form>
{% endblock %}

{% block body %}
<div style="max-width:900px">

    {# Header card #}
    <div class="admin-table-section" style="padding:24px;margin-bottom:1.5rem">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:1rem">
            <div>
                <h2 style="font-family:Sora,sans-serif;font-size:22px;font-weight:700;color:#1a1730;margin-bottom:10px">{{ evenement.titre }}</h2>
                <div style="display:flex;flex-wrap:wrap;gap:8px">
                    {% if evenement.categorie %}
                        <span class="admin-badge admin-badge-blue">{{ evenement.categorie.nomCategorie }}</span>
                    {% endif %}
                    <span class="admin-badge admin-badge-green">{{ evenement.typeEvenement }}</span>
                    <span class="admin-status-dot {{ evenement.statut == 'Actif' ? 'dot-active' : (evenement.statut == 'Complet' ? 'dot-pending' : 'dot-refuse') }}">● {{ evenement.statut }}</span>
                </div>
            </div>
            <div style="font-size:12px;color:#9999b8">
                Créé le {{ evenement.dateCreation ? evenement.dateCreation|date('d/m/Y à H:i') : '—' }}
            </div>
        </div>
    </div>

    {# Info grid #}
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1.5rem">
        <div class="admin-table-section" style="padding:18px">
            <div style="font-size:11px;color:#9999b8;font-weight:600;text-transform:uppercase;margin-bottom:6px">📅 Date début</div>
            <div style="font-size:16px;font-weight:700;color:#1a1730">{{ evenement.dateDebut|date('d/m/Y') }}</div>
        </div>
        <div class="admin-table-section" style="padding:18px">
            <div style="font-size:11px;color:#9999b8;font-weight:600;text-transform:uppercase;margin-bottom:6px">📅 Date fin</div>
            <div style="font-size:16px;font-weight:700;color:#1a1730">{{ evenement.dateFin|date('d/m/Y') }}</div>
            <div style="font-size:11px;color:#9999b8;margin-top:3px">{{ evenement.dureeJours }} jour(s)</div>
        </div>
        <div class="admin-table-section" style="padding:18px">
            <div style="font-size:11px;color:#9999b8;font-weight:600;text-transform:uppercase;margin-bottom:6px">📍 Lieu</div>
            <div style="font-size:15px;font-weight:600;color:#1a1730">{{ evenement.lieu ?? '—' }}</div>
        </div>
        <div class="admin-table-section" style="padding:18px">
            <div style="font-size:11px;color:#9999b8;font-weight:600;text-transform:uppercase;margin-bottom:6px">💰 Prix</div>
            {% if evenement.prix and evenement.prix > 0 %}
                <div style="font-size:16px;font-weight:700;color:#16a34a">{{ evenement.prix }} TND</div>
            {% else %}
                <div style="font-size:15px;font-weight:600;color:#16a34a">Gratuit</div>
            {% endif %}
        </div>
    </div>

    {# Capacity #}
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1.5rem">
        <div class="admin-table-section" style="padding:18px">
            <div style="font-size:11px;color:#9999b8;font-weight:600;text-transform:uppercase;margin-bottom:6px">👥 Capacité max</div>
            <div style="font-size:22px;font-weight:700;color:#6C63FF">{{ evenement.capaciteMax }}</div>
        </div>
        <div class="admin-table-section" style="padding:18px">
            <div style="font-size:11px;color:#9999b8;font-weight:600;text-transform:uppercase;margin-bottom:6px">✅ Places réservées</div>
            <div style="font-size:22px;font-weight:700;color:#1a1730">{{ evenement.placesReservees }}</div>
        </div>
        <div class="admin-table-section" style="padding:18px">
            <div style="font-size:11px;color:#9999b8;font-weight:600;text-transform:uppercase;margin-bottom:6px">🎟 Places restantes</div>
            {% set pct = evenement.capaciteMax > 0 ? (evenement.placesReservees / evenement.capaciteMax * 100) : 0 %}
            <div style="font-size:22px;font-weight:700;color:{{ evenement.full ? '#dc2626' : '#16a34a' }}">{{ evenement.placesRestantesCalculated }}</div>
            <div style="height:6px;background:#e2e5ea;border-radius:4px;margin-top:8px;overflow:hidden">
                <div style="height:100%;width:{{ pct > 100 ? 100 : pct }}%;background:{{ pct >= 100 ? '#dc2626' : (pct >= 75 ? '#d97706' : '#16a34a') }};border-radius:4px"></div>
            </div>
            <div style="font-size:11px;color:#9999b8;margin-top:4px">{{ pct|round }}% occupé</div>
        </div>
    </div>

    {# Description #}
    {% if evenement.description %}
    <div class="admin-table-section" style="padding:24px;margin-bottom:1.5rem">
        <div style="font-size:11px;color:#9999b8;font-weight:600;text-transform:uppercase;margin-bottom:10px">📝 Description</div>
        <p style="font-size:14px;color:#1a1730;line-height:1.7;margin:0">{{ evenement.description|nl2br }}</p>
    </div>
    {% endif %}

    {# Image #}
    {% if evenement.imagePath %}
    <div class="admin-table-section" style="padding:24px">
        <div style="font-size:11px;color:#9999b8;font-weight:600;text-transform:uppercase;margin-bottom:10px">🖼 Image</div>
        <div style="text-align:center">
            <img src="{{ asset(evenement.imagePath) }}" alt="{{ evenement.titre }}"
                 style="max-width:100%;max-height:320px;border-radius:10px;object-fit:cover"
                 onerror="this.style.display='none'">
        </div>
    </div>
    {% endif %}

</div>
{% endblock %}
