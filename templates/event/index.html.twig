{% extends 'admin_base.html.twig' %}
{% block title %}Événements{% endblock %}
{% block page_icon %}📅{% endblock %}
{% block page_title %}Gestion des Événements{% endblock %}
{% block topbar_actions %}
    <a href="{{ path('evenement_new') }}" class="btn btn-primary" style="background:linear-gradient(135deg,#6C63FF,#9D6BFF);border:none;border-radius:10px;padding:10px 20px;font-weight:600;text-decoration:none;color:#fff;">+ Nouvel Événement</a>
{% endblock %}

{% block body %}
<div style="display:flex;gap:4px;margin-bottom:1.5rem;border-bottom:2px solid #e5e7ef;padding-bottom:0">
    <a href="{{ path('evenement_index') }}"
       style="padding:9px 18px;font-size:13px;font-weight:600;border-radius:8px 8px 0 0;text-decoration:none;border:1.5px solid transparent;border-bottom:none;margin-bottom:-2px;{% if app.request.attributes.get('_route') == 'evenement_index' %}background:#fff;border-color:#e5e7ef;color:#6c63ff;border-bottom-color:#fff;{% else %}color:#9ca3af;{% endif %}">
        📅 Événements
    </a>
    <a href="{{ path('evenement_categories') }}"
       style="padding:9px 18px;font-size:13px;font-weight:600;border-radius:8px 8px 0 0;text-decoration:none;border:1.5px solid transparent;border-bottom:none;margin-bottom:-2px;{% if app.request.attributes.get('_route') == 'evenement_categories' %}background:#fff;border-color:#e5e7ef;color:#6c63ff;border-bottom-color:#fff;{% else %}color:#9ca3af;{% endif %}">
        🏷️ Catégories
    </a>
    <a href="{{ path('evenement_inscriptions') }}"
       style="padding:9px 18px;font-size:13px;font-weight:600;border-radius:8px 8px 0 0;text-decoration:none;border:1.5px solid transparent;border-bottom:none;margin-bottom:-2px;{% if app.request.attributes.get('_route') == 'evenement_inscriptions' %}background:#fff;border-color:#e5e7ef;color:#6c63ff;border-bottom-color:#fff;{% else %}color:#9ca3af;{% endif %}">
        📋 Inscriptions
    </a>
</div>

<div class="admin-quick-cards" style="grid-template-columns:repeat(4,1fr)">
    <div class="quick-card">
        <div class="quick-card-icon" style="background:rgba(108,99,255,.1)">📅</div>
        <div class="quick-card-title">Total</div>
        <div style="font-size:1.6rem;font-weight:700;color:#1a1730">{{ total }}</div>
    </div>
    <div class="quick-card">
        <div class="quick-card-icon" style="background:rgba(34,197,94,.1)">✅</div>
        <div class="quick-card-title">Actifs</div>
        <div style="font-size:1.6rem;font-weight:700;color:#16a34a">{{ stats.Actif ?? 0 }}</div>
    </div>
    <div class="quick-card">
        <div class="quick-card-icon" style="background:rgba(245,158,11,.1)">⬤</div>
        <div class="quick-card-title">Complets</div>
        <div style="font-size:1.6rem;font-weight:700;color:#d97706">{{ stats.Complet ?? 0 }}</div>
    </div>
    <div class="quick-card">
        <div class="quick-card-icon" style="background:rgba(239,68,68,.1)">✕</div>
        <div class="quick-card-title">Annulés/Terminés</div>
        <div style="font-size:1.6rem;font-weight:700;color:#dc2626">{{ (stats.Annulé ?? 0) + (stats.Terminé ?? 0) }}</div>
    </div>
</div>

<div class="admin-table-section">
    <div class="admin-table-header">
        <div class="admin-table-title">
            Liste des Événements
            <span class="admin-count-badge">{{ evenements|length }}</span>
        </div>
        <div class="admin-table-actions">
            <form method="GET" action="{{ path('evenement_index') }}" id="filterForm" style="display:flex;gap:8px;align-items:center">
                <input type="text" name="search" value="{{ search }}" placeholder="Rechercher..." class="admin-search-input" oninput="clearTimeout(window._st);window._st=setTimeout(()=>this.form.submit(),350)">
                <select name="statut" class="admin-search-input" style="width:auto" onchange="this.form.submit()">
                    <option value="">Tous statuts</option>
                    {% for s in ['Actif','Complet','Annulé','Terminé'] %}
                        <option value="{{ s }}" {% if statut == s %}selected{% endif %}>{{ s }}</option>
                    {% endfor %}
                </select>
                <a href="{{ path('evenement_index') }}" class="admin-tool-btn">✕ Reset</a>
            </form>
        </div>
    </div>

    {% if evenements is empty %}
        <div class="admin-body empty-state"><div class="empty-icon">📅</div><p class="empty-title">Aucun événement trouvé</p></div>
    {% else %}
    <table class="admin-table">
        <thead><tr>
            <th>Titre</th><th>Catégorie</th><th>Dates</th><th>Lieu</th>
            <th>Capacité</th><th>Prix</th><th>Statut</th><th style="text-align:right">Actions</th>
        </tr></thead>
        <tbody>
        {% for ev in evenements %}
        <tr>
            <td>
                <div class="admin-table-name">{{ ev.titre }}</div>
                {% if ev.description %}<div class="admin-table-muted" style="font-size:12px">{{ ev.description|slice(0,55) }}{% if ev.description|length > 55 %}…{% endif %}</div>{% endif %}
            </td>
            <td>{% if ev.categorie %}<span class="admin-badge admin-badge-blue">{{ ev.categorie.nomCategorie }}</span>{% else %}<span class="admin-table-muted">—</span>{% endif %}</td>
            <td class="admin-table-muted" style="font-size:13px;white-space:nowrap">{{ ev.dateDebut|date('d/m/Y') }}{% if ev.dateFin != ev.dateDebut %}<br>→ {{ ev.dateFin|date('d/m/Y') }}{% endif %}</td>
            <td class="admin-table-muted" style="font-size:13px">{{ ev.lieu ?? '—' }}</td>
            <td style="font-size:13px">{{ ev.placesReservees }}/{{ ev.capaciteMax }}</td>
            <td>{% if ev.prix and ev.prix > 0 %}<span style="font-weight:700;color:#16a34a">{{ ev.prix }} TND</span>{% else %}<span class="admin-badge admin-badge-green">Gratuit</span>{% endif %}</td>
            <td>
                {% if ev.statut == 'Actif' %}<span class="admin-status-dot dot-active">● {{ ev.statut }}</span>
                {% elseif ev.statut == 'Complet' %}<span class="admin-status-dot dot-pending">● {{ ev.statut }}</span>
                {% else %}<span class="admin-status-dot dot-refuse">● {{ ev.statut }}</span>{% endif %}
            </td>
            <td>
                <div class="admin-row-actions" style="justify-content:flex-end">
                    <a href="{{ path('evenement_show', {id: ev.id}) }}" class="admin-action-btn">👁</a>
                    <a href="{{ path('evenement_edit', {id: ev.id}) }}" class="admin-action-btn">✏️</a>
                    <form method="post" action="{{ path('evenement_delete', {id: ev.id}) }}" onsubmit="return confirm('Supprimer ?')" style="display:inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_evenement_' ~ ev.id) }}">
                        <button type="submit" class="admin-action-btn admin-action-delete">🗑</button>
                    </form>
                </div>
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>
{% endblock %}
