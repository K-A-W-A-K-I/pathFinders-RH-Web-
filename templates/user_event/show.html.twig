{% block javascripts %}
<div id="userConfirmModal" style="display:none;position:fixed;inset:0;z-index:999999;align-items:center;justify-content:center;">
    <div id="pfModalBackdrop" style="position:fixed;inset:0;background:rgba(15,23,42,0.55);backdrop-filter:blur(4px);"></div>
    <div id="pfModalInner" style="position:relative;z-index:1000000;background:white;border-radius:24px;max-width:440px;width:90%;padding:32px 28px;text-align:center;box-shadow:0 26px 70px rgba(15,23,42,0.22);">
        <div id="userConfirmIcon" style="width:64px;height:64px;margin:0 auto 18px;border-radius:20px;display:flex;align-items:center;justify-content:center;font-size:28px;background:linear-gradient(135deg,#eef2ff,#ddd6fe);color:#2729aa;"><i class="bi bi-star-fill"></i></div>
        <h5 id="userConfirmTitle" style="font-size:20px;font-weight:800;color:#010204;margin:0 0 8px;"></h5>
        <p  id="userConfirmText"  style="font-size:13px;color:#64748b;line-height:1.6;margin:0 0 22px;"></p>
        <div style="display:flex;justify-content:center;gap:10px;">
            <button type="button" id="pfModalCancel" style="border:none;border-radius:10px;padding:11px 22px;font-size:13px;font-weight:700;cursor:pointer;background:#eef2ff;color:#2729aa;">Annuler</button>
            <button type="button" id="userConfirmSubmit" style="border:none;border-radius:10px;padding:11px 22px;font-size:13px;font-weight:700;cursor:pointer;background:#2729aa;color:white;">Confirmer</button>
        </div>
    </div>
</div>
<script>
let _pfPendingForm = null;
function openUserConfirm(button) {
    _pfPendingForm = button.closest('form');
    document.getElementById('userConfirmTitle').textContent = button.dataset.confirmTitle || 'Confirmation';
    document.getElementById('userConfirmText').innerHTML    = button.dataset.confirmText  || '';
    document.getElementById('userConfirmModal').style.display = 'flex';
}
document.getElementById('pfModalBackdrop').addEventListener('click', () => { document.getElementById('userConfirmModal').style.display='none'; });
document.getElementById('pfModalCancel').addEventListener('click',   () => { document.getElementById('userConfirmModal').style.display='none'; });
document.getElementById('userConfirmSubmit').addEventListener('click', () => { if (_pfPendingForm) _pfPendingForm.submit(); });
</script>

{% if evenement.lieu %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function(){
    var lieu = {{ evenement.lieu|json_encode|raw }};
    fetch('https://nominatim.openstreetmap.org/search?format=json&limit=1&q='+encodeURIComponent(lieu))
    .then(function(r){return r.json();})
    .then(function(data){
        var el=document.getElementById('evd-map'); if(!el)return;
        var lat=36.8189,lng=10.1658;
        if(data&&data.length>0){lat=parseFloat(data[0].lat);lng=parseFloat(data[0].lon);}
        var osmUrl='https://www.openstreetmap.org/?mlat='+lat+'&mlon='+lng+'#map=15/'+lat+'/'+lng;
        var lnk=document.getElementById('evd-map-link'); if(lnk)lnk.href=osmUrl;
        var map=L.map('evd-map',{zoomControl:true,scrollWheelZoom:false}).setView([lat,lng],14);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'© OpenStreetMap',maxZoom:19}).addTo(map);
        var icon=L.divIcon({html:'<div style="background:linear-gradient(135deg,#6c63ff,#9d6bff);width:32px;height:32px;border-radius:50% 50% 50% 0;transform:rotate(-45deg);border:3px solid #fff;box-shadow:0 4px 12px rgba(108,99,255,.5)"></div>',iconSize:[32,32],iconAnchor:[16,32],className:''});
        L.marker([lat,lng],{icon:icon}).addTo(map).bindPopup('<strong>'+lieu+'</strong><br><a href="'+osmUrl+'" target="_blank" style="color:#6c63ff;font-weight:600">Voir sur OpenStreetMap</a>').openPopup();
    }).catch(function(){
        var el=document.getElementById('evd-map');
        if(el)el.innerHTML='<div style="display:flex;align-items:center;justify-content:center;height:100%;color:#9ca3af;font-size:14px">Carte non disponible</div>';
    });
})();
</script>
{% endif %}

<script>
// ── Event data ──────────────────────────────────────────────────────────────
var PFE = {
    titre:      {{ evenement.titre|json_encode|raw }},
    description:{{ evenement.description|default('')|json_encode|raw }},
    lieu:       {{ evenement.lieu|default('Non précisé')|json_encode|raw }},
    dateDebut:  {{ evenement.dateDebut|date('d/m/Y')|json_encode|raw }},
    dateFin:    {{ evenement.dateFin|date('d/m/Y')|json_encode|raw }},
    prix:       parseFloat('{{ evenement.prix|default(0) }}'),
    statut:     {{ evenement.statut|json_encode|raw }},
    type:       {{ evenement.typeEvenement|json_encode|raw }},
    capacite:   {{ evenement.capaciteMax }},
    restantes:  {{ evenement.placesRestantesCalculated }},
    reservees:  {{ evenement.placesReservees }},
    isReg:      {{ isRegistered ? 'true' : 'false' }},
    uid:        {{ currentUserId ?? 'null' }},
    rUrl:       '{{ path('user_evenement_register', {id: evenement.id}) }}',
    cUrl:       '{{ path('user_evenement_checkout', {id: evenement.id}) }}',
    rTok:       '{{ csrf_token('register_evenement_' ~ evenement.id) }}',
    cTok:       '{{ csrf_token('checkout_evenement_' ~ evenement.id) }}',
    gcUrl:      'https://calendar.google.com/calendar/render?action=TEMPLATE&text={{ evenement.titre|url_encode }}&dates={{ evenement.dateDebut|date('Ymd') }}/{{ evenement.dateFin|date('Ymd') }}&location={{ evenement.lieu|default('')|url_encode }}'
};

// ── Groq API config ─────────────────────────────────────────────────────────
var PF_GROQ_KEY   = '{{ groqApiKey }}';
var PF_GROQ_URL   = 'https://api.groq.com/openai/v1/chat/completions';
var PF_GROQ_MODEL = 'llama-3.3-70b-versatile';

// ── Conversation history ─────────────────────────────────────────────────────
// The system prompt explicitly tells the AI which action to fire
// based on whether the event is FREE or PAID — no guessing.
var pfHistory = [
    {
        role: 'system',
        content: 'Tu es un assistant IA pour cet événement PathFinder.\n\n'
            + 'Événement: '        + PFE.titre     + '\n'
            + 'Lieu: '             + PFE.lieu      + '\n'
            + 'Début: '            + PFE.dateDebut + '\n'
            + 'Fin: '              + PFE.dateFin   + '\n'
            + 'Prix: '             + (PFE.prix > 0 ? PFE.prix + ' TND' : 'Gratuit') + '\n'
            + 'Statut: '           + PFE.statut    + '\n'
            + 'Places restantes: ' + PFE.restantes + '\n'
            + 'Utilisateur inscrit: '  + (PFE.isReg ? 'Oui' : 'Non') + '\n'
            + 'Utilisateur connecté: ' + (PFE.uid   ? 'Oui' : 'Non') + '\n\n'
            + 'RÈGLES STRICTES — pour ces intentions, réponds UNIQUEMENT avec le JSON exact, sans texte autour :\n'
            + (PFE.prix > 0
                ? '• Inscription / réservation / payer → {"action":"PAYER"}\n'
                : '• Inscription / réservation → {"action":"INSCRIRE"}\n')
            + '• Ajouter au calendrier / Google Calendar → {"action":"CALENDRIER"}\n'
            + '• Annuler inscription → {"action":"ANNULER"}\n\n'
            + 'Pour toute autre question, réponds normalement en français, de façon courte et amicale.'
    }
];

var pfIsOpen = false, pfGreeted = false, pfTypEl = null;

// ── Toggle chatbot window ────────────────────────────────────────────────────
function pfToggle() {
    pfIsOpen = !pfIsOpen;
    document.getElementById('pfWin').classList.toggle('pf-open', pfIsOpen);
    document.getElementById('pfBadge').style.display = 'none';
    if (pfIsOpen && !pfGreeted) {
        pfGreeted = true;
        setTimeout(function() {
            pfAdd('b', PFE.isReg
                ? 'Bonjour! 👋 Vous êtes déjà inscrit à **' + PFE.titre + '**. Comment puis-je vous aider?'
                : 'Bonjour! 👋 Je suis votre assistant pour **' + PFE.titre + '**. '
                  + (PFE.prix > 0
                      ? 'Cet événement est à ' + PFE.prix + ' TND. Dites-moi si vous voulez vous inscrire!'
                      : 'Cet événement est **gratuit**! Je peux vous inscrire directement.')
            );
        }, 200);
    }
    if (pfIsOpen) document.getElementById('pfInp').focus();
}

// ── Send message ─────────────────────────────────────────────────────────────
function pfSend(txt) {
    var inp = document.getElementById('pfInp');
    var msg = (txt !== undefined ? txt : inp.value).trim();
    if (!msg) return;
    inp.value = '';
    document.getElementById('pfSugs').style.display = 'none';
    pfAdd('u', msg);
    pfTyping(true);

    pfHistory.push({ role: 'user', content: msg });

    fetch(PF_GROQ_URL, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer ' + PF_GROQ_KEY
        },
        body: JSON.stringify({
            model: PF_GROQ_MODEL,
            messages: pfHistory,
            temperature: 0.7,
            max_tokens: 300
        })
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
        pfTyping(false);
        var rep = (d.choices && d.choices[0] && d.choices[0].message)
            ? d.choices[0].message.content
            : 'Désolé, une erreur est survenue.';
        pfHistory.push({ role: 'assistant', content: rep });
        // Try to parse as action JSON first
        try {
            var j = JSON.parse(rep.trim());
            if (j.action) { pfAction(j.action); return; }
        } catch(e) {}
        pfAdd('b', rep);
    })
    .catch(function(err) {
        pfTyping(false);
        pfAdd('b', 'Erreur de connexion. Veuillez réessayer.');
        console.error('Groq API error:', err);
    });
}

// ── Handle actions ────────────────────────────────────────────────────────────
function pfAction(a) {
    if (!PFE.uid) {
        pfAdd('b', 'Vous devez être connecté pour effectuer cette action. <a href="/connexion" style="color:#6C63FF;font-weight:600">Se connecter →</a>');
        return;
    }

    if (a === 'INSCRIRE') {
        // Safety: if event is paid, redirect to payment instead
        if (PFE.prix > 0) { pfAction('PAYER'); return; }
        if (PFE.isReg)           { pfAdd('b', '✅ Vous êtes déjà inscrit à cet événement!'); return; }
        if (PFE.restantes <= 0)  { pfAdd('b', '😔 Désolé, cet événement est complet.'); return; }
        pfAdd('b', '⏳ Inscription en cours...');
        pfSubmit(PFE.rUrl, PFE.rTok);

    } else if (a === 'PAYER') {
        // Safety: if event is free, register directly instead
        if (PFE.prix <= 0) { pfAction('INSCRIRE'); return; }
        if (PFE.isReg)           { pfAdd('b', '✅ Vous êtes déjà inscrit!'); return; }
        if (PFE.restantes <= 0)  { pfAdd('b', '😔 Désolé, cet événement est complet.'); return; }
        pfAdd('b', '💳 Redirection vers le paiement...');
        setTimeout(function() { pfSubmit(PFE.cUrl, PFE.cTok); }, 700);

    } else if (a === 'CALENDRIER') {
        window.open(PFE.gcUrl, '_blank');
        pfAdd('b', '📅 Google Calendar ouvert dans un nouvel onglet!');

    } else if (a === 'ANNULER') {
        pfAdd('b', '⚠️ Pour annuler votre inscription, veuillez contacter l\'organisateur depuis votre espace personnel.');
    }
}

// ── Submit form helper ────────────────────────────────────────────────────────
function pfSubmit(url, tok) {
    var f = document.createElement('form');
    f.method = 'POST'; f.action = url;
    var i = document.createElement('input');
    i.type = 'hidden'; i.name = '_token'; i.value = tok;
    f.appendChild(i);
    document.body.appendChild(f);
    f.submit();
}

// ── Typing indicator ──────────────────────────────────────────────────────────
function pfTyping(show) {
    var msgs = document.getElementById('pfMsgs');
    if (show) {
        pfTypEl = document.createElement('div');
        pfTypEl.className = 'pf-m b';
        pfTypEl.innerHTML = '<div class="pf-av">🤖</div><div class="pf-bub pf-dot"><span></span><span></span><span></span></div>';
        msgs.appendChild(pfTypEl);
        msgs.scrollTop = msgs.scrollHeight;
    } else {
        if (pfTypEl) { pfTypEl.remove(); pfTypEl = null; }
    }
}

// ── Add message bubble ────────────────────────────────────────────────────────
function pfAdd(role, text) {
    var msgs = document.getElementById('pfMsgs');
    var d   = document.createElement('div'); d.className = 'pf-m ' + role;
    var av  = document.createElement('div'); av.className = 'pf-av'; av.textContent = role === 'b' ? '🤖' : '👤';
    var bub = document.createElement('div'); bub.className = 'pf-bub';
    bub.innerHTML = text
        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
        .replace(/\n/g, '<br>');
    d.appendChild(av); d.appendChild(bub);
    msgs.appendChild(d);
    msgs.scrollTop = msgs.scrollHeight;
    if (!pfIsOpen) {
        var b = document.getElementById('pfBadge');
        b.style.display = 'flex'; b.textContent = '1';
    }
}

// ── Init ──────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', function() {
    document.getElementById('pfBtn').addEventListener('click', pfToggle);
    document.getElementById('pfClose').addEventListener('click', pfToggle);
    document.getElementById('pfSub').addEventListener('click', function() { pfSend(); });
    document.getElementById('pfInp').addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); pfSend(); }
    });
    document.querySelectorAll('.pf-s').forEach(function(el) {
        el.addEventListener('click', function() { pfSend(this.textContent.trim()); });
    });
    setTimeout(function() {
        if (!pfIsOpen) {
            var b = document.getElementById('pfBadge');
            b.style.display = 'flex'; b.textContent = '1';
        }
    }, 4000);
});
</script>
{% endblock %}
