{% extends 'dashboard/base_dashboard.html.twig' %}
{% block title %}{{ title }} — Dashboard{% endblock %}

{% block body %}
<div class="topbar">
  <div class="page-title"><span style="font-size:22px">📄</span><h1>{{ title }}</h1></div>
  <a href="{{ path('dashboard_home') }}" class="btn-secondary">← Retour</a>
</div>

<div class="form-section">
  {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

    <div class="form-group">
      {{ form_label(form.formation) }}
      {{ form_widget(form.formation, {attr: {class: form.formation.vars.errors|length ? 'is-invalid' : ''}}) }}
      {% for error in form.formation.vars.errors %}
        <div class="form-errors">{{ error.message }}</div>
      {% endfor %}
    </div>

    <div class="form-group">
      {{ form_label(form.nom) }}
      {{ form_widget(form.nom, {attr: {class: form.nom.vars.errors|length ? 'is-invalid' : ''}}) }}
      {% for error in form.nom.vars.errors %}
        <div class="form-errors">{{ error.message }}</div>
      {% endfor %}
    </div>

    <div class="form-group">
      {{ form_label(form.contenu) }}
      {{ form_widget(form.contenu, {attr: {class: form.contenu.vars.errors|length ? 'is-invalid' : ''}}) }}
      {% for error in form.contenu.vars.errors %}
        <div class="form-errors">{{ error.message }}</div>
      {% endfor %}
    </div>

    <div class="form-group">
      {{ form_label(form.ordre) }}
      {{ form_widget(form.ordre, {attr: {class: form.ordre.vars.errors|length ? 'is-invalid' : ''}}) }}
      {% for error in form.ordre.vars.errors %}
        <div class="form-errors">{{ error.message }}</div>
      {% endfor %}
    </div>

    <div style="display:flex;gap:.8rem;margin-top:1.8rem;padding-top:1.2rem;border-top:1px solid var(--border)">
      <button type="submit" class="btn-primary">💾 Enregistrer</button>
      <a href="{{ path('dashboard_home') }}" class="btn-secondary">Annuler</a>
    </div>
  {{ form_end(form) }}
</div>
{% endblock %}
