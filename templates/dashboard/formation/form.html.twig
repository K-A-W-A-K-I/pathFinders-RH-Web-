{% extends 'admin_base.html.twig' %}
{% block title %}{{ title }} — Dashboard{% endblock %}
{% block page_icon %}🎓{% endblock %}
{% block page_title %}{{ title }}{% endblock %}
{% block topbar_actions %}
    <a href="{{ path('dash_formation_index') }}" class="admin-tool-btn">← Retour</a>
{% endblock %}

{% block body %}
<div style="display:grid;grid-template-columns:1fr 340px;gap:1.5rem;max-width:1100px">

    {# Left column #}
    <div>
        <div class="admin-table-section" style="padding:28px;margin-bottom:1.5rem">
            <div style="font-size:13px;font-weight:700;color:#9999b8;text-transform:uppercase;letter-spacing:.06em;margin-bottom:1.2rem">Informations générales</div>
            {{ form_start(form, {attr: {novalidate: 'novalidate', id: 'formation-form'}}) }}

            <div style="margin-bottom:1rem">
                {{ form_label(form.titre) }}
                {{ form_widget(form.titre, {attr: {class: form.titre.vars.errors|length ? 'is-invalid' : '', style: 'width:100%;padding:10px 14px;border:1.5px solid #e2e5ea;border-radius:9px;font-size:14px;font-family:DM Sans,sans-serif;outline:none;' ~ (form.titre.vars.errors|length ? 'border-color:#ef4444;' : '')}}) }}
                {% for error in form.titre.vars.errors %}<div style="color:#dc2626;font-size:12px;margin-top:3px">⚠ {{ error.message }}</div>{% endfor %}
            </div>

            <div style="margin-bottom:1rem">
                {{ form_label(form.description) }}
                {{ form_widget(form.description, {attr: {rows: 4, style: 'width:100%;padding:10px 14px;border:1.5px solid #e2e5ea;border-radius:9px;font-size:14px;font-family:DM Sans,sans-serif;outline:none;resize:vertical;' ~ (form.description.vars.errors|length ? 'border-color:#ef4444;' : '')}}) }}
                {% for error in form.description.vars.errors %}<div style="color:#dc2626;font-size:12px;margin-top:3px">⚠ {{ error.message }}</div>{% endfor %}
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem">
                <div>
                    {{ form_label(form.categorie) }}
                    {{ form_widget(form.categorie, {attr: {style: 'width:100%;padding:10px 14px;border:1.5px solid #e2e5ea;border-radius:9px;font-size:14px;font-family:DM Sans,sans-serif;outline:none;'}}) }}
                    {% for error in form.categorie.vars.errors %}<div style="color:#dc2626;font-size:12px;margin-top:3px">⚠ {{ error.message }}</div>{% endfor %}
                </div>
                <div>
                    {{ form_label(form.formateur) }}
                    {{ form_widget(form.formateur, {attr: {style: 'width:100%;padding:10px 14px;border:1.5px solid #e2e5ea;border-radius:9px;font-size:14px;font-family:DM Sans,sans-serif;outline:none;' ~ (form.formateur.vars.errors|length ? 'border-color:#ef4444;' : '')}}) }}
                    {% for error in form.formateur.vars.errors %}<div style="color:#dc2626;font-size:12px;margin-top:3px">⚠ {{ error.message }}</div>{% endfor %}
                </div>
            </div>
        </div>

        <div class="admin-table-section" style="padding:28px">
            <div style="font-size:13px;font-weight:700;color:#9999b8;text-transform:uppercase;letter-spacing:.06em;margin-bottom:1.2rem">Dates & Capacité</div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
                <div>
                    {{ form_label(form.dateDebut) }}
                    {{ form_widget(form.dateDebut, {attr: {id: 'date_debut', style: 'width:100%;padding:10px 14px;border:1.5px solid #e2e5ea;border-radius:9px;font-size:14px;font-family:DM Sans,sans-serif;outline:none;' ~ (form.dateDebut.vars.errors|length ? 'border-color:#ef4444;' : '')}}) }}
                    {% for error in form.dateDebut.vars.errors %}<div style="color:#dc2626;font-size:12px;margin-top:3px">⚠ {{ error.message }}</div>{% endfor %}
                </div>
                <div>
                    {{ form_label(form.dateFin) }}
                    {{ form_widget(form.dateFin, {attr: {id: 'date_fin', style: 'width:100%;padding:10px 14px;border:1.5px solid #e2e5ea;border-radius:9px;font-size:14px;font-family:DM Sans,sans-serif;outline:none;' ~ (form.dateFin.vars.errors|length ? 'border-color:#ef4444;' : '')}}) }}
                    {% for error in form.dateFin.vars.errors %}<div style="color:#dc2626;font-size:12px;margin-top:3px">⚠ {{ error.message }}</div>{% endfor %}
                </div>
                <div>
                    {{ form_label(form.dureeHeures) }}
                    {{ form_widget(form.dureeHeures, {attr: {style: 'width:100%;padding:10px 14px;border:1.5px solid #e2e5ea;border-radius:9px;font-size:14px;font-family:DM Sans,sans-serif;outline:none;' ~ (form.dureeHeures.vars.errors|length ? 'border-color:#ef4444;' : '')}}) }}
                    {% for error in form.dureeHeures.vars.errors %}<div style="color:#dc2626;font-size:12px;margin-top:3px">⚠ {{ error.message }}</div>{% endfor %}
                </div>
                <div>
                    {{ form_label(form.capaciteMax) }}
                    {{ form_widget(form.capaciteMax, {attr: {id: 'capacite_max', style: 'width:100%;padding:10px 14px;border:1.5px solid #e2e5ea;border-radius:9px;font-size:14px;font-family:DM Sans,sans-serif;outline:none;' ~ (form.capaciteMax.vars.errors|length ? 'border-color:#ef4444;' : '')}}) }}
                    {% for error in form.capaciteMax.vars.errors %}<div style="color:#dc2626;font-size:12px;margin-top:3px">⚠ {{ error.message }}</div>{% endfor %}
                </div>
                <div>
                    {{ form_label(form.placeDisponible) }}
                    {{ form_widget(form.placeDisponible, {attr: {id: 'place_dispo', style: 'width:100%;padding:10px 14px;border:1.5px solid #e2e5ea;border-radius:9px;font-size:14px;font-family:DM Sans,sans-serif;outline:none;' ~ (form.placeDisponible.vars.errors|length ? 'border-color:#ef4444;' : '')}}) }}
                    {% for error in form.placeDisponible.vars.errors %}<div style="color:#dc2626;font-size:12px;margin-top:3px">⚠ {{ error.message }}</div>{% endfor %}
                </div>
            </div>
        </div>
    </div>

    {# Right column #}
    <div>
        <div class="admin-table-section" style="padding:24px">
            <button type="submit" form="formation-form" class="btn btn-primary" style="width:100%;background:linear-gradient(135deg,#6C63FF,#9D6BFF);border:none;border-radius:10px;padding:12px;font-weight:600;font-size:15px;color:#fff;cursor:pointer;margin-bottom:10px">
                💾 Enregistrer
            </button>
            <a href="{{ path('dash_formation_index') }}" class="admin-tool-btn" style="width:100%;justify-content:center;display:flex">Annuler</a>
        </div>
    </div>

</div>
{{ form_end(form) }}
{% endblock %}

{% block javascripts %}
<script>
const capaciteInput = document.getElementById('capacite_max');
const placesInput   = document.getElementById('place_dispo');
const dateDebut     = document.getElementById('date_debut');
const dateFin       = document.getElementById('date_fin');

function checkPlaces() {
    if (!capaciteInput || !placesInput) return;
    const cap = parseInt(capaciteInput.value) || 0;
    const pl  = parseInt(placesInput.value) || 0;
    placesInput.style.borderColor = (pl > cap && cap > 0) ? '#ef4444' : '';
}
function checkDates() {
    if (!dateDebut || !dateFin || !dateDebut.value || !dateFin.value) return;
    dateFin.style.borderColor = dateFin.value <= dateDebut.value ? '#ef4444' : '';
}
if (capaciteInput) capaciteInput.addEventListener('input', checkPlaces);
if (placesInput)   placesInput.addEventListener('input', checkPlaces);
if (dateDebut)     dateDebut.addEventListener('change', checkDates);
if (dateFin)       dateFin.addEventListener('change', checkDates);
</script>
{% endblock %}
