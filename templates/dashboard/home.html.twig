{% extends 'dashboard/base_dashboard.html.twig' %}
{% block title %}Tableau de bord — PathFinder{% endblock %}

{% block stylesheets %}
<style>
.dash-tabs{display:flex;gap:.5rem;margin-bottom:24px;border-bottom:2px solid var(--border);padding-bottom:0}
.dash-tab{padding:10px 22px;font-size:14px;font-weight:600;color:var(--text-light);cursor:pointer;border-radius:8px 8px 0 0;border:none;background:transparent;font-family:'DM Sans',sans-serif;transition:color .2s;border-bottom:2px solid transparent;margin-bottom:-2px}
.dash-tab:hover{color:var(--primary)}
.dash-tab.active{color:var(--primary);border-bottom-color:var(--primary);background:var(--primary-light)}
.tab-panel{display:none}.tab-panel.active{display:block}
.stat-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:28px}
.stat-card{background:var(--white);border-radius:var(--radius);padding:22px;box-shadow:var(--shadow);border:1px solid var(--border);animation:fadeUp .4s ease both}
.stat-card:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(108,99,255,.12)}
.stat-num{font-family:'Sora',sans-serif;font-size:2rem;font-weight:700;color:var(--text-dark)}
.stat-label{font-size:13px;color:var(--text-light);margin-top:.2rem}
</style>
{% endblock %}

{% block body %}
<div class="topbar">
  <div class="page-title">
    <span style="font-size:22px">📊</span>
    <h1>Tableau de bord RH</h1>
  </div>
</div>

<div class="stat-cards">
  <div class="stat-card">
    <div style="font-size:1.8rem;margin-bottom:.6rem">📂</div>
    <div class="stat-num">{{ nbCategories }}</div>
    <div class="stat-label">Catégories</div>
  </div>
  <div class="stat-card" style="animation-delay:.08s">
    <div style="font-size:1.8rem;margin-bottom:.6rem">🎓</div>
    <div class="stat-num">{{ nbFormations }}</div>
    <div class="stat-label">Formations</div>
  </div>
  <div class="stat-card" style="animation-delay:.16s">
    <div style="font-size:1.8rem;margin-bottom:.6rem">✅</div>
    <div class="stat-num">{{ nbInscriptions }}</div>
    <div class="stat-label">Inscriptions</div>
  </div>
</div>

<!-- TABS -->
<div class="dash-tabs">
  <button class="dash-tab active" onclick="showTab('categories')">📂 Catégories</button>
  <button class="dash-tab" onclick="showTab('formations')">🎓 Formations</button>
  <button class="dash-tab" onclick="showTab('inscriptions')">✅ Inscriptions</button>
</div>

{# ── TAB CATÉGORIES ── #}
<div id="tab-categories" class="tab-panel active">
  <div class="table-section">
    <div class="table-header">
      <div class="table-title">
        <h2>Catégories</h2>
        <span class="count-badge">{{ categories|length }}</span>
      </div>
      <div class="table-actions">
        <input type="text" id="search-cat" placeholder="Rechercher..." class="search-input" oninput="filterTable('tbl-cat', this.value)">
        <select id="sort-cat" class="pf-select" onchange="sortCategories(this.value)">
          <option value="nom-asc">Nom (A-Z)</option>
          <option value="nom-desc">Nom (Z-A)</option>
          <option value="formations-asc">Formations (croissant)</option>
          <option value="formations-desc">Formations (décroissant)</option>
        </select>
        <a href="{{ path('dash_categorie_new') }}" class="btn-primary" style="padding:8px 18px">+ Nouvelle</a>
      </div>
    </div>
    {% if categories is empty %}
      <p style="color:var(--text-light);text-align:center;padding:2rem">Aucune catégorie. <a href="{{ path('dash_categorie_new') }}" style="color:var(--primary)">Créer la première →</a></p>
    {% else %}
      <table id="tbl-cat">
        <thead><tr>
          <th>Nom</th><th>Description</th><th>Image</th><th>Formations</th><th style="text-align:right">Actions</th>
        </tr></thead>
        <tbody>
          {% for cat in categories %}
            <tr>
              <td><strong>{{ cat.nomCategorie }}</strong></td>
              <td style="color:var(--text-light);font-size:13px;max-width:200px">{{ cat.description ? cat.description|slice(0,60) ~ '...' : '—' }}</td>
              <td>
                {% if cat.image %}
                  <img src="{{ cat.image }}" alt="" style="width:36px;height:36px;object-fit:cover;border-radius:6px" onerror="this.style.display='none'">
                {% else %}—{% endif %}
              </td>
              <td><span class="tag tag-purple">{{ cat.formations|length }}</span></td>
              <td>
                <div class="action-btns">
                  <button type="button" class="btn-action success btn-show-formations" data-catid="{{ cat.idCategorie }}">👁 Formations</button>
                  <a href="{{ path('dash_categorie_edit', {id: cat.idCategorie}) }}" class="btn-action">✏️ Modifier</a>
                  <form method="post" action="{{ path('dash_categorie_delete', {id: cat.idCategorie}) }}" onsubmit="return confirm('Supprimer cette catégorie ?')" style="display:inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_cat_' ~ cat.idCategorie) }}">
                    <button type="submit" class="btn-action danger">🗑 Supprimer</button>
                  </form>
                </div>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>
</div>

{# ── TAB FORMATIONS ── #}
<div id="tab-formations" class="tab-panel">
  <div class="table-section">
    <div class="table-header">
      <div class="table-title">
        <h2>Formations</h2>
        <span class="count-badge">{{ formations|length }}</span>
      </div>
      <div class="table-actions">
        <input type="text" id="search-form" placeholder="Rechercher..." class="search-input" oninput="filterTable('tbl-form', this.value)">
        <select id="filter-cat" class="pf-select" onchange="filterByCat(this.value)">
          <option value="">Toutes catégories</option>
          {% for cat in categories %}
            <option value="{{ cat.idCategorie }}">{{ cat.nomCategorie }}</option>
          {% endfor %}
        </select>
        <select id="sort-form" class="pf-select" onchange="sortFormations(this.value)">
          <option value="titre-asc">Titre (A-Z)</option>
          <option value="titre-desc">Titre (Z-A)</option>
          <option value="duree-asc">Durée (croissant)</option>
          <option value="duree-desc">Durée (décroissant)</option>
          <option value="places-asc">Places (croissant)</option>
          <option value="places-desc">Places (décroissant)</option>
        </select>
        <a href="{{ path('dash_formation_new') }}" class="btn-primary" style="padding:8px 18px">+ Nouvelle</a>
      </div>
    </div>
    {% if formations is empty %}
      <p style="color:var(--text-light);text-align:center;padding:2rem">Aucune formation. <a href="{{ path('dash_formation_new') }}" style="color:var(--primary)">Créer la première →</a></p>
    {% else %}
      <table id="tbl-form">
        <thead><tr>
          <th>Titre</th><th>Catégorie</th><th>Formateur</th><th>Durée</th><th>Places</th><th>Dates</th><th style="text-align:right">Actions</th>
        </tr></thead>
        <tbody>
          {% for f in formations %}
            <tr data-catid="{{ f.categorie.idCategorie }}">
              <td><strong>{{ f.titre }}</strong></td>
              <td><span class="tag tag-purple">{{ f.categorie.nomCategorie }}</span></td>
              <td style="color:var(--text-light);font-size:13px">{{ f.formateur ?? '—' }}</td>
              <td style="color:var(--text-light);font-size:13px">{{ f.dureeHeures ? f.dureeHeures ~ 'h' : '—' }}</td>
              <td>
                {% if f.placeDisponible > 0 %}
                  <span class="tag tag-green">{{ f.placeDisponible }}/{{ f.capaciteMax }}</span>
                {% else %}
                  <span class="tag tag-red">Complet</span>
                {% endif %}
              </td>
              <td style="color:var(--text-light);font-size:12px">
                {{ f.dateDebut ? f.dateDebut|date('d/m/Y') : '—' }} →
                {{ f.dateFin ? f.dateFin|date('d/m/Y') : '—' }}
              </td>
              <td>
                <div class="action-btns">
                  <a href="{{ path('dash_formation_inscriptions', {id: f.idFormation}) }}" class="btn-action success">👥 Inscrits</a>
                  <a href="{{ path('dash_contenu_by_formation', {formationId: f.idFormation}) }}" class="btn-action">📄 Modules</a>
                  <a href="{{ path('dash_formation_edit', {id: f.idFormation}) }}" class="btn-action">✏️ Modifier</a>
                  <form method="post" action="{{ path('dash_formation_delete', {id: f.idFormation}) }}" onsubmit="return confirm('Supprimer cette formation ?')" style="display:inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_form_' ~ f.idFormation) }}">
                    <button type="submit" class="btn-action danger">🗑</button>
                  </form>
                </div>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>
</div>

{# ── TAB INSCRIPTIONS ── #}
<div id="tab-inscriptions" class="tab-panel">
  <div class="table-section">
    <div class="table-header">
      <div class="table-title">
        <h2>Toutes les inscriptions</h2>
        <span class="count-badge">{{ nbInscriptions }}</span>
      </div>
      <div class="table-actions">
        <input type="text" placeholder="Rechercher..." class="search-input" oninput="filterTable('tbl-insc', this.value)">
      </div>
    </div>
    {% if allInscriptions is empty %}
      <p style="color:var(--text-light);text-align:center;padding:2rem">Aucune inscription pour le moment.</p>
    {% else %}
      <table id="tbl-insc">
        <thead><tr>
          <th>#</th><th>Participant</th><th>Email</th><th>Formation</th><th>Date</th>
        </tr></thead>
        <tbody>
          {% for insc in allInscriptions %}
            <tr>
              <td style="color:var(--text-light);font-size:13px">{{ loop.index }}</td>
              <td><strong>{{ insc.nomParticipant ?? '—' }}</strong></td>
              <td style="color:var(--text-light);font-size:13px">{{ insc.emailParticipant ?? '—' }}</td>
              <td><span class="tag tag-purple">{{ insc.formation.titre }}</span></td>
              <td style="color:var(--text-light);font-size:13px">{{ insc.dateInscription|date('d/m/Y H:i') }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
function showTab(name) {
  document.querySelectorAll('.dash-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  document.querySelectorAll('.dash-tab').forEach(t => {
    if (t.getAttribute('onclick') && t.getAttribute('onclick').includes("'" + name + "'")) {
      t.classList.add('active');
    }
  });
}

function filterTable(tableId, q) {
  document.querySelectorAll('#' + tableId + ' tbody tr').forEach(row => {
    row.style.display = row.innerText.toLowerCase().includes(q.toLowerCase()) ? '' : 'none';
  });
}

function filterByCat(catId) {
  document.querySelectorAll('#tbl-form tbody tr').forEach(row => {
    row.style.display = (!catId || row.dataset.catid === catId) ? '' : 'none';
  });
}

function sortCategories(sortValue) {
  const [field, dir] = sortValue.split('-');
  const tbody = document.querySelector('#tbl-cat tbody');
  const rows = Array.from(tbody.querySelectorAll('tr'));
  
  rows.sort((a, b) => {
    let valA, valB;
    if (field === 'nom') {
      valA = a.cells[0].textContent.trim().toLowerCase();
      valB = b.cells[0].textContent.trim().toLowerCase();
    } else if (field === 'formations') {
      valA = parseInt(a.cells[3].textContent.trim()) || 0;
      valB = parseInt(b.cells[3].textContent.trim()) || 0;
    }
    
    if (dir === 'asc') return valA > valB ? 1 : -1;
    return valA < valB ? 1 : -1;
  });
  
  rows.forEach(row => tbody.appendChild(row));
}

function sortFormations(sortValue) {
  const [field, dir] = sortValue.split('-');
  const tbody = document.querySelector('#tbl-form tbody');
  const rows = Array.from(tbody.querySelectorAll('tr'));
  
  rows.sort((a, b) => {
    let valA, valB;
    if (field === 'titre') {
      valA = a.cells[0].textContent.trim().toLowerCase();
      valB = b.cells[0].textContent.trim().toLowerCase();
    } else if (field === 'duree') {
      valA = parseFloat(a.cells[3].textContent.replace('h', '').trim()) || 0;
      valB = parseFloat(b.cells[3].textContent.replace('h', '').trim()) || 0;
    } else if (field === 'places') {
      const textA = a.cells[4].textContent.trim();
      const textB = b.cells[4].textContent.trim();
      valA = textA.includes('Complet') ? 0 : parseInt(textA.split('/')[0]) || 0;
      valB = textB.includes('Complet') ? 0 : parseInt(textB.split('/')[0]) || 0;
    }
    
    if (dir === 'asc') return valA > valB ? 1 : -1;
    return valA < valB ? 1 : -1;
  });
  
  rows.forEach(row => tbody.appendChild(row));
}

// Boutons "Formations" dans l'onglet catégories
document.querySelectorAll('.btn-show-formations').forEach(btn => {
  btn.addEventListener('click', function() {
    const catId = this.dataset.catid;
    showTab('formations');
    const sel = document.getElementById('filter-cat');
    if (sel) { sel.value = catId; filterByCat(catId); }
  });
});

// Lire le tab depuis l'URL
const urlParams = new URLSearchParams(window.location.search);
const tab = urlParams.get('tab');
if (tab) showTab(tab);
</script>
{% endblock %}
