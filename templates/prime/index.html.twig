{% extends 'admin_base.html.twig' %}
{% block title %}Primes — PathFinder{% endblock %}
{% block page_icon %}🏆{% endblock %}
{% block page_title %}Gestion des Primes{% endblock %}
{% block topbar_actions %}
    <a href="{{ path('prime_new') }}" class="btn btn-primary" style="background:linear-gradient(135deg,#6C63FF,#9D6BFF);border:none;border-radius:10px;padding:10px 20px;font-weight:600;text-decoration:none;color:#fff;">+ Nouvelle Prime</a>
{% endblock %}

{% block body %}
<div class="admin-table-section">
    <div class="admin-table-header">
        <div class="admin-table-title">
            Liste des Primes
            <span class="admin-count-badge">{{ primes|length }}</span>
        </div>
    </div>
    <table class="admin-table">
        <thead><tr>
            <th>Libellé</th><th>Montant</th><th>Type</th><th>Date</th><th>Employé</th><th style="text-align:right">Actions</th>
        </tr></thead>
        <tbody>
        {% for prime in primes %}
        <tr>
            <td class="admin-table-name">{{ prime.libelle }}</td>
            <td style="font-weight:700;color:#16a34a">{{ prime.montant }} DT</td>
            <td><span class="admin-badge admin-badge-blue">{{ prime.typePrime }}</span></td>
            <td class="admin-table-muted">{{ prime.dateAttribution ? prime.dateAttribution|date('d/m/Y') : '—' }}</td>
            <td>{{ prime.fichesPaiement ? prime.fichesPaiement.employee.utilisateur.nom ~ ' ' ~ prime.fichesPaiement.employee.utilisateur.prenom : '—' }}</td>
            <td>
                <div class="admin-row-actions" style="justify-content:flex-end">
                    <a href="{{ path('prime_edit', {id: prime.id}) }}" class="admin-action-btn">✏️</a>
                    <form method="post" action="{{ path('prime_delete', {id: prime.id}) }}" onsubmit="return confirm('Supprimer ?')" style="display:inline">
                        <button type="submit" class="admin-action-btn admin-action-delete">🗑</button>
                    </form>
                </div>
            </td>
        </tr>
        {% else %}
        <tr><td colspan="6" style="text-align:center;color:#9999b8;padding:2rem">Aucune prime disponible</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
