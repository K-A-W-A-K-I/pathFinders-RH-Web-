{% extends 'base.html.twig' %}
{% block title %}Primes — PathFinder{% endblock %}

{% block body %}

<h1 class="section-title">Primes</h1>

<a href="{{ path('prime_new') }}" class="btn-new">+ Nouvelle Prime</a>

<div class="table-container">
  <table class="pf-table">
    <thead>
      <tr>
        <th>Libellé</th>
        <th>Montant</th>
        <th>Type</th>
        <th>Date</th>
        <th>Employé</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      {% for prime in primes %}
        <tr class="row-animate">
          <td>{{ prime.libelle }}</td>
          <td>{{ prime.montant }} DT</td>
          <td>{{ prime.typePrime }}</td>
          <td>{{ prime.dateAttribution ? prime.dateAttribution|date('Y-m-d') : '-' }}</td>
          <td>
            {{ prime.fichesPaiement.employee.utilisateur.nom }}
            {{ prime.fichesPaiement.employee.utilisateur.prenom }}
          </td>
          <td class="actions">
            <a href="{{ path('prime_edit', {id: prime.id}) }}" class="btn-edit">Modifier</a>
            <form method="post" action="{{ path('prime_delete', {id: prime.id}) }}" class="inline-form">
              <button type="submit" class="btn-delete" onclick="return confirm('Supprimer cette prime ?')">Supprimer</button>
            </form>
          </td>
        </tr>
      {% else %}
        <tr>
          <td colspan="6" class="empty-row">Aucune prime disponible</td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<style>
.section-title { font-size: 2rem; font-weight: 700; color: #4A4A4A; margin-bottom: 20px; }
.table-container { overflow-x: auto; margin-top: 20px; border-radius: 10px; background: white; padding: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
.pf-table { width: 100%; border-collapse: collapse; font-family: 'Arial', sans-serif; }
.pf-table thead { background: linear-gradient(90deg, #6C63FF, #8A84FF); color: white; }
.pf-table th, .pf-table td { padding: 14px 18px; text-align: left; border-bottom: 1px solid #eee; }
.pf-table tbody tr:nth-child(even) { background-color: #fafafa; }
.pf-table tbody tr:hover { background-color: #f0edff; transition: 0.2s ease-in-out; }
.row-animate { animation: fadeIn 0.4s ease forwards; opacity: 0; }
@keyframes fadeIn { to { opacity: 1; } }
.btn-new { display: inline-block; margin-bottom: 15px; background-color: #6C63FF; color: white; padding: 10px 18px; text-decoration: none; border-radius: 6px; font-weight: bold; transition: 0.2s; }
.btn-new:hover { background-color: #5a54e6; }
.btn-edit { background-color: #4B8BF5; color: white; padding: 6px 12px; text-decoration: none; border-radius: 4px; font-size: 0.9rem; transition: 0.2s; }
.btn-edit:hover { background-color: #3a78e0; }
.btn-delete { background-color: #FF5C5C; color: white; padding: 6px 12px; border: none; border-radius: 4px; font-size: 0.9rem; cursor: pointer; transition: 0.2s; }
.btn-delete:hover { background-color: #e04a4a; }
.empty-row { text-align: center; color: #777; padding: 20px; font-style: italic; }
.inline-form { display: inline; }
</style>

{% endblock %}