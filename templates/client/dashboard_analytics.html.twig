// ── Chart: Corrélation scatter ─────────────────────────────────────
function buildCorr() {
  charts['correlation'] = true;
  const pts = formationsJs.map(f => ({
    x: f.capaciteMax,
    y: nbInscritsMap[f.id] ?? 0,
    label: f.titre,
  }));
  new Chart(document.getElementById('cCorr'), {
    type: 'scatter',
    data: {
      datasets: [{
        label: 'Formation',
        data: pts,
        backgroundColor: 'rgba(108,99,255,.65)',
        pointRadius: 7, pointHoverRadius: 9,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: { label: ctx => `${pts[ctx.dataIndex].label}: cap ${ctx.parsed.x} / ${ctx.parsed.y} ins.` } }
      },
      scales: {
        x: { title: { display: true, text: 'Capacité max', color: textC, font: { size: 11 } }, grid: { color: gridC }, ticks: { color: textC } },
        y: { beginAtZero: true, title: { display: true, text: 'Nb inscrits', color: textC, font: { size: 11 } }, grid: { color: gridC }, ticks: { color: textC } },
      }
    }
  });
}

// ── Chart: Régression ──────────────────────────────────────────────
function buildReg() {
  charts['regression'] = true;
  const scatter = formationsJs.map(f => ({ x: f.capaciteMax, y: nbInscritsMap[f.id] ?? 0 }));
  const minX = Math.min(...formationsJs.map(f => f.capaciteMax));
  const maxX = Math.max(...formationsJs.map(f => f.capaciteMax));
  const line = [
    { x: minX, y: Math.round((regA * minX + regB) * 100) / 100 },
    { x: maxX, y: Math.round((regA * maxX + regB) * 100) / 100 },
  ];
  new Chart(document.getElementById('cReg'), {
    type: 'scatter',
    data: {
      datasets: [
        {
          label: 'Formations',
          data: scatter,
          backgroundColor: 'rgba(108,99,255,.65)',
          pointRadius: 6, pointHoverRadius: 8,
        },
        {
          label: 'Régression',
          data: line,
          type: 'line',
          borderColor: '#EF4444',
          borderWidth: 2,
          borderDash: [5, 3],
          pointRadius: 0, fill: false, showLine: true,
        },
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { title: { display: true, text: 'Capacité max', color: textC, font: { size: 11 } }, grid: { color: gridC }, ticks: { color: textC } },
        y: { beginAtZero: true, title: { display: true, text: 'Nb inscrits', color: textC, font: { size: 11 } }, grid: { color: gridC }, ticks: { color: textC } },
      }
    }
  });
}
