{% extends 'client/base_client.html.twig' %}
{% block title %}{{ formation.titre }} — PathFinder{% endblock %}
{% block nav_categories %}active{% endblock %}

{% block body %}
<div class="pf-hero">
  <div class="pf-hero-bg"></div><div class="pf-hero-grid"></div>
  <div class="pf-hero-inner">
    <div class="pf-hero-badge"><div class="pf-hero-badge-dot"></div>{{ formation.categorie.nomCategorie }}</div>
    <h1><span>{{ formation.titre }}</span></h1>
    <p>{{ formation.description ?? '' }}</p>
  </div>
</div>

<div class="pf-content">
  <div style="margin-bottom:1rem">
    <a href="{{ path('client_formations_by_categorie', {id: formation.categorie.idCategorie}) }}" style="color:var(--text-muted);text-decoration:none;font-size:14px">← Retour aux formations</a>
  </div>

  <div style="display:grid;grid-template-columns:2fr 1fr;gap:1.5rem;align-items:start">
    <div>
      <div class="pf-section">
        <div class="pf-section-label">Informations</div>
        <h2>Détails de la formation</h2>
        <div class="pf-divider"></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
          {% if formation.formateur %}<div><span style="color:var(--text-dim);font-size:12px;text-transform:uppercase;letter-spacing:.08em">Formateur</span><p style="margin-top:.3rem;font-weight:500">{{ formation.formateur }}</p></div>{% endif %}
          {% if formation.dureeHeures %}<div><span style="color:var(--text-dim);font-size:12px;text-transform:uppercase;letter-spacing:.08em">Durée</span><p style="margin-top:.3rem;font-weight:500">{{ formation.dureeHeures }}h</p></div>{% endif %}
          {% if formation.dateDebut %}<div><span style="color:var(--text-dim);font-size:12px;text-transform:uppercase;letter-spacing:.08em">Date début</span><p style="margin-top:.3rem;font-weight:500">{{ formation.dateDebut|date('d/m/Y') }}</p></div>{% endif %}
          {% if formation.dateFin %}<div><span style="color:var(--text-dim);font-size:12px;text-transform:uppercase;letter-spacing:.08em">Date fin</span><p style="margin-top:.3rem;font-weight:500">{{ formation.dateFin|date('d/m/Y') }}</p></div>{% endif %}
          <div><span style="color:var(--text-dim);font-size:12px;text-transform:uppercase;letter-spacing:.08em">Capacité max</span><p style="margin-top:.3rem;font-weight:500">{{ formation.capaciteMax }}</p></div>
          <div><span style="color:var(--text-dim);font-size:12px;text-transform:uppercase;letter-spacing:.08em">Places disponibles</span><p style="margin-top:.3rem;font-weight:500">{{ formation.placeDisponible }}</p></div>
        </div>
      </div>

      {% if isInscrit %}
        <div class="pf-section">
          <div class="pf-section-label">Contenu de la formation</div>
          <h2>Modules</h2>
          <div class="pf-divider"></div>
          {% if contenuModules is empty %}
            <p style="color:var(--text-muted)">Aucun module disponible pour le moment.</p>
          {% else %}
            {% for module in contenuModules %}
              <a href="{{ path('client_module_detail', {id: module.idContenu}) }}" style="display:block;border:.5px solid var(--border);border-radius:12px;padding:1.2rem;margin-bottom:.8rem;text-decoration:none;color:var(--text);transition:background .2s,border-color .2s,transform .2s">
                <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.6rem">
                  <span style="background:var(--primary);color:#fff;width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0">{{ module.ordre ?? loop.index }}</span>
                  <strong style="font-family:'Sora',sans-serif">{{ module.nom }}</strong>
                  <span style="margin-left:auto;color:var(--text-muted);font-size:12px">→</span>
                </div>
                {% if module.contenu %}
                  <p style="color:var(--text-muted);font-size:14px;line-height:1.7">{{ module.contenu|slice(0, 120) }}{% if module.contenu|length > 120 %}...{% endif %}</p>
                {% endif %}
              </a>
            {% endfor %}
          {% endif %}
        </div>
      {% else %}
        <div class="pf-section" style="text-align:center;padding:2.5rem">
          <div style="font-size:2.5rem;margin-bottom:1rem">🔒</div>
          <h3 style="font-family:'Sora',sans-serif;margin-bottom:.5rem">Contenu réservé aux inscrits</h3>
          <p style="color:var(--text-muted);font-size:14px">Inscrivez-vous à cette formation pour accéder à tous les modules de contenu.</p>
        </div>
      {% endif %}
    </div>

    <div class="pf-section" style="position:sticky;top:80px">
      {% if isInscrit %}
        <div style="text-align:center;padding:1rem 0">
          <div style="font-size:2rem;margin-bottom:.8rem">✅</div>
          <h3 style="font-family:'Sora',sans-serif;color:var(--teal);margin-bottom:.4rem">Vous êtes inscrit</h3>
          <p style="color:var(--text-muted);font-size:13px">Vous avez accès au contenu de cette formation.</p>
          <button disabled style="width:100%;margin-top:1.2rem;padding:12px;border-radius:10px;border:none;background:rgba(29,158,117,.15);color:var(--teal);font-size:14px;font-weight:600;cursor:not-allowed">Déjà inscrit</button>
        </div>
      {% elseif formation.placeDisponible <= 0 %}
        <div style="text-align:center;padding:1rem 0">
          <div style="font-size:2rem;margin-bottom:.8rem">❌</div>
          <h3 style="font-family:'Sora',sans-serif;color:var(--red);margin-bottom:.4rem">Formation complète</h3>
          <p style="color:var(--text-muted);font-size:13px">Aucune place disponible.</p>
          <button disabled style="width:100%;margin-top:1.2rem;padding:12px;border-radius:10px;border:none;background:rgba(226,75,74,.15);color:var(--red);font-size:14px;font-weight:600;cursor:not-allowed">Inscription fermée</button>
        </div>
      {% else %}
        <div class="pf-section-label">S'inscrire</div>
        <h3 style="font-family:'Sora',sans-serif;margin-bottom:1rem;font-size:1rem">Rejoindre cette formation</h3>
        <p style="color:var(--text-muted);font-size:13px;margin-bottom:1.5rem">Cliquez sur le bouton ci-dessous pour vous inscrire instantanément à cette formation.</p>
        <form method="post" action="{{ path('client_formation_inscrire', {id: formation.idFormation}) }}">
          <button type="submit" style="width:100%;padding:12px;border-radius:10px;border:none;background:linear-gradient(135deg,var(--primary),var(--accent));color:#fff;font-size:14px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;transition:transform .2s,box-shadow .2s">
            ✨ S'inscrire maintenant
          </button>
        </form>
        <p style="color:var(--text-dim);font-size:11px;margin-top:1rem;text-align:center">Inscription gratuite et instantanée</p>
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}
