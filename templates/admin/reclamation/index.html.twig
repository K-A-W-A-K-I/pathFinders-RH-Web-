{% extends 'admin_base.html.twig' %}
{% block title %}Réclamations{% endblock %}
{% block page_icon %}📋{% endblock %}
{% block page_title %}Gestion des Réclamations{% endblock %}

{% block body %}
<div class="admin-table-section">
    <div class="admin-table-header">
        <div class="admin-table-title">
            Réclamations
            <span class="admin-count-badge">{{ reclamations|length }}</span>
        </div>
        <div class="admin-table-actions">
            <input type="text" id="searchInput" placeholder="Rechercher..." class="admin-search-input" oninput="filterTable(this.value)">
            <select id="statutFilter" class="admin-search-input" style="width:auto" onchange="filterTable(document.getElementById('searchInput').value)">
                <option value="">Tous les statuts</option>
                <option value="En attente">En attente</option>
                <option value="En cours">En cours</option>
                <option value="Résolu">Résolu</option>
                <option value="Fermé">Fermé</option>
            </select>
        </div>
    </div>

    {% if reclamations is empty %}
        <div style="text-align:center;color:#9999b8;padding:3rem">Aucune réclamation.</div>
    {% else %}
    <table class="admin-table" id="reclTable">
        <thead><tr>
            <th>Utilisateur</th><th>Titre</th><th>Description</th><th>Statut</th><th>Date</th><th style="text-align:right">Actions</th>
        </tr></thead>
        <tbody>
        {% for r in reclamations %}
        {% set u = users[r.idUtilisateur] ?? null %}
        <tr data-statut="{{ r.statut }}">
            <td class="admin-table-name">{{ u ? u.fullName : 'Utilisateur #' ~ r.idUtilisateur }}</td>
            <td style="font-weight:500;color:#1a1730;max-width:200px">{{ r.titre }}</td>
            <td class="admin-table-muted" style="max-width:250px;font-size:13px">{{ r.description|slice(0,80) }}{% if r.description|length > 80 %}…{% endif %}</td>
            <td>
                <form method="post" action="{{ path('admin_reclamation_statut', {id: r.id}) }}" style="display:inline">
                    <select name="statut" onchange="this.form.submit()"
                            style="padding:4px 10px;border-radius:8px;font-size:12px;font-weight:600;border:1.5px solid #e2e5ea;cursor:pointer;
                            background:{% if r.statut == 'En attente' %}rgba(245,158,11,.1){% elseif r.statut == 'En cours' %}rgba(75,139,245,.1){% elseif r.statut == 'Résolu' %}rgba(34,197,94,.1){% else %}rgba(100,116,139,.1){% endif %};
                            color:{% if r.statut == 'En attente' %}#d97706{% elseif r.statut == 'En cours' %}#2563eb{% elseif r.statut == 'Résolu' %}#16a34a{% else %}#64748b{% endif %}">
                        {% for s in ['En attente','En cours','Résolu','Fermé'] %}
                            <option value="{{ s }}" {{ r.statut == s ? 'selected' : '' }}>{{ s }}</option>
                        {% endfor %}
                    </select>
                </form>
            </td>
            <td class="admin-table-muted" style="font-size:12px;white-space:nowrap">{{ r.dateCreation|date('d/m/Y H:i') }}</td>
            <td>
                <div class="admin-row-actions" style="justify-content:flex-end">
                    <form method="post" action="{{ path('admin_reclamation_delete', {id: r.id}) }}" onsubmit="return confirm('Supprimer ?')" style="display:inline">
                        <button type="submit" class="admin-action-btn admin-action-delete">🗑</button>
                    </form>
                </div>
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
<script>
function filterTable(q) {
    const statut = document.getElementById('statutFilter').value.toLowerCase();
    const query  = q.toLowerCase();
    document.querySelectorAll('#reclTable tbody tr').forEach(row => {
        const text     = row.textContent.toLowerCase();
        const rowStatut = (row.dataset.statut || '').toLowerCase();
        row.style.display = text.includes(query) && (!statut || rowStatut === statut) ? '' : 'none';
    });
}
</script>
{% endblock %}
