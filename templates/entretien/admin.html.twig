{% extends 'admin_base.html.twig' %}
{% block title %}Gestion des Entretiens{% endblock %}
{% block page_icon %}🎓{% endblock %}
{% block page_title %}Gestion des Entretiens{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('entretien_admin') }}" class="btn btn-secondary" style="display:inline-flex;align-items:center;gap:6px;padding:9px 18px;border-radius:10px;font-weight:600;text-decoration:none;background:var(--white);color:var(--text-light);border:1px solid var(--border)">🔄 Rafraîchir</a>
{% endblock %}

{% block body %}

{# ── Filter bar ── #}
<div class="admin-filter-row">
    <form method="get" style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
        {% for opt in ['Tous', 'En attente', 'Confirmés', 'Refusés'] %}
            <a href="?statut={{ opt }}"
               class="admin-filter-chip {{ filter == opt ? 'active' : '' }}">
                {{ opt }}
            </a>
        {% endfor %}
        <span class="admin-count-badge" style="margin-left:auto">{{ entretiens|length }} entretien(s)</span>
    </form>
</div>

{# ── Table ── #}
<div class="admin-table-section">
    <table class="admin-table">
        <thead>
            <tr>
                <th>CANDIDAT</th>
                <th>OFFRE</th>
                <th>DATE & HEURE</th>
                <th>STATUT</th>
                <th>NOTES</th>
                <th>ACTIONS</th>
            </tr>
        </thead>
        <tbody>
        {% if entretiens is empty %}
            <tr><td colspan="6" class="empty-cell">Aucun entretien pour le moment.</td></tr>
        {% else %}
            {% for e in entretiens %}
            <tr>
                <td class="admin-table-name">{{ e.candidat.fullName }}</td>
                <td class="admin-table-muted">{{ e.offre.titre }}</td>
                <td class="admin-table-muted">{{ e.dateEntretien|date('d/m/Y H:i') }}</td>
                <td><span class="admin-status-dot {{ e.statut == 'CONFIRME' ? 'dot-active' : (e.statut == 'REFUSE' ? 'dot-refuse' : 'dot-pending') }}">● {{ e.statutLabel }}</span></td>
                <td class="admin-table-muted">
                    {% if e.interviewCompleted %}
                        <span style="color:var(--primary);font-size:12px;font-weight:600">🤖 Entretien IA complété</span>
                    {% elseif e.notes %}
                        {{ e.notes|slice(0, 60) }}{% if e.notes|length > 60 %}…{% endif %}
                    {% else %}
                        —
                    {% endif %}
                </td>
                <td>
                    <div class="admin-row-actions">
                        {% if e.statut != 'CONFIRME' %}
                        <form method="post" action="{{ path('entretien_update_statut', {id: e.id}) }}" class="inline-form" onsubmit="return promptNotes(this)">
                            <input type="hidden" name="statut" value="CONFIRME">
                            <input type="hidden" name="notes" class="notes-input">
                            <button type="submit" class="btn btn-sm btn-success">✅ Confirmer</button>
                        </form>
                        {% endif %}
                        {% if e.statut != 'REFUSE' %}
                        <form method="post" action="{{ path('entretien_update_statut', {id: e.id}) }}" class="inline-form" onsubmit="return promptNotes(this)">
                            <input type="hidden" name="statut" value="REFUSE">
                            <input type="hidden" name="notes" class="notes-input">
                            <button type="submit" class="btn btn-sm btn-danger">❌ Refuser</button>
                        </form>
                        {% endif %}
                        <a href="{{ path('interview_admin_result', {id: e.id}) }}" class="btn btn-sm" style="background:var(--primary-light);color:var(--primary);border:1px solid #c7d2fe">
                            🤖 Résultat IA{% if e.interviewCompleted %} <span style="background:#22c55e;color:#fff;border-radius:99px;padding:1px 6px;font-size:10px;margin-left:4px">{{ e.interviewScore }}/100</span>{% endif %}
                        </a>
                        {% if e.interviewToken and app.debug %}
                        <a href="{{ path('interview_chat', {token: e.interviewToken}) }}" target="_blank" class="btn btn-sm" style="background:#fef9c3;color:#b45309;border:1px solid #fde047" title="Lien de test (dev uniquement)">
                            🔗 Test lien
                        </a>
                        {% endif %}
                    </div>
                </td>
            </tr>
            {% endfor %}
        {% endif %}
        </tbody>
    </table>
</div>

<div class="info-banner" style="margin-top:16px">
    💡 Confirmez ou refusez les demandes d'entretien. Les créneaux confirmés bloquent automatiquement les autres candidats.
</div>

<script>
function promptNotes(form) {
    const notes = prompt('Notes (facultatif) :') ?? '';
    form.querySelector('.notes-input').value = notes;
    return true;
}
</script>
{% endblock %}
